#!/usr/bin/env python3
#
# INET-specific fingerprint test tool.
# Imports opp_fingerprinttest and overrides inet-specific configuration.
#

import importlib.util
import importlib.machinery
import os
import sys

# Import opp_fingerprinttest (no .py extension, so use importlib)
script_dir = os.path.dirname(os.path.abspath(__file__))
loader = importlib.machinery.SourceFileLoader("opp_fingerprinttest", os.path.join(script_dir, "opp_fingerprinttest"))
spec = importlib.util.spec_from_loader("opp_fingerprinttest", loader)
opp = importlib.util.module_from_spec(spec)
spec.loader.exec_module(opp)

# Override inet-specific configuration
opp.cpuTimeLimit = "600s"
opp.defaultFingerprintCalculator = 'inet::FingerprintCalculator'
opp.defaultExecutable = "inet"
opp.fpExtraArgs = {
    "~tND": { "'--**.checksumMode=\"computed\"'",
              "'--**.fcsMode=\"computed\"'"
            },
    "tyf" : { "--cmdenv-fake-gui=true",
              "--cmdenv-fake-gui-before-event-probability=0.001",
              "--cmdenv-fake-gui-after-event-probability=0.001",
              "--cmdenv-fake-gui-on-hold-probability=0.001",
              "--cmdenv-fake-gui-on-hold-numsteps=3",
              "--cmdenv-fake-gui-on-simtime-probability=0.001",
              "--cmdenv-fake-gui-on-simtime-numsteps=3",
              "'--**.fadeOutMode=\"animationTime\"'",
              "'--**.signalAnimationSpeedChangeTimeMode=\"animationTime\"'"
            }
}

opp.main()
