<environment>
    <!-- A wall between the access point and sta[0]. DielectricObstacleLoss attenuates (does not
         block) the AP<->sta[0] link through it, so rate control settles that link near 6 Mbps;
         the other stations are not behind the wall and stay at 54 Mbps. Thickness tunes the
         attenuation; z is centered on the nodes' z=0 plane so the ray passes cleanly through. -->
    <object position="min 12 16.05 -1.5" orientation="0 0 0" shape="cuboid 10 1.9 3"
            material="concrete" fill-color="160 160 160" opacity="0.9"/>
</environment>
