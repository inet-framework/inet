<LispConfig>
    <Router id="xtr1">
        <LISP>
            <EtrMapServer address="10.0.0.3" key="keyA" proxy="enabled"/>
            <ItrMapResolver address="10.0.0.3"/>
            <EtrMapping>
                <EID address="192.168.1.0/24">
                    <RLOC address="10.0.0.1" priority="1" weight="100"/>
                </EID>
            </EtrMapping>
        </LISP>
    </Router>
    <Router id="xtr2">
        <LISP>
            <EtrMapServer address="10.0.0.3" key="keyB" proxy="enabled"/>
            <ItrMapResolver address="10.0.0.3"/>
            <EtrMapping>
                <EID address="192.168.2.0/24">
                    <RLOC address="10.0.0.2" priority="1" weight="100"/>
                </EID>
            </EtrMapping>
        </LISP>
    </Router>
    <Router id="ms">
        <LISP>
            <MapServer ipv4="enabled">
                <Site name="siteA" key="keyA"><EID address="192.168.1.0/24"/></Site>
                <Site name="siteB" key="keyB"><EID address="192.168.2.0/24"/></Site>
            </MapServer>
            <MapResolver ipv4="enabled"/>
        </LISP>
    </Router>
</LispConfig>
