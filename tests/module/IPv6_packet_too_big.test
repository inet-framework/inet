%description:
Tests that a router sends ICMPv6 Packet Too Big when a forwarded packet
exceeds the outgoing interface's MTU.

NClientsEth example network is used (cli -- r1 -- r2 -- r3 -- srv).
The r2-r3 link has a reduced MTU (576 bytes). The client sends a large
UDP datagram (1200 bytes) which traverses r1 and arrives at r2. At r2,
the datagram exceeds the MTU of the outgoing interface toward r3,
triggering ICMPv6 PACKET_TOO_BIG.

%#--------------------------------------------------------------------------------------------------------------
%inifile: omnetpp.ini
[General]
ned-path = ../../../../examples;../../../../src
network = inet.examples.ipv6.nclients.NClientsEth
sim-time-limit = 15s
cmdenv-express-mode = false
cmdenv-log-prefix = "%C: "

#omnetpp 5.0 - 5.1 compatibility:
eventlog-file = "${resultdir}/${configname}-${runnumber}.elog"
output-scalar-file = "${resultdir}/${configname}-${runnumber}.sca"
output-vector-file = "${resultdir}/${configname}-${runnumber}.vec"
snapshot-file = "${resultdir}/${configname}-${runnumber}.sna"

# number of client computers
*.n = 1

# Reduce MTU on r2's interface toward r3 to trigger Packet Too Big
*.r2.eth[1].*.mtu = 576B

# udp apps: send a large datagram that will exceed the reduced MTU
**.cli[*].numApps = 1
**.cli[*].app[0].typename = "UdpBasicApp"
**.cli[*].app[0].destAddresses = "srv"
**.cli[*].app[0].destPort = 1000
**.cli[*].app[0].messageLength = 1200B

**.cli[*].app[0].startTime = 10s
**.cli[*].app[0].stopTime = 11s
**.cli[*].app[0].sendInterval = 10s

**.srv.numApps = 1
**.srv.app[0].typename = "UdpSink"
**.srv.app[0].localPort = 1000

# Ethernet NIC configuration
**.eth[*].queue.typename = "EthernetQosQueue"
**.eth[*].queue.dataQueue.typename = "DropTailQueue" # in routers
**.eth[*].queue.dataQueue.packetCapacity = 10  # in routers

%#--------------------------------------------------------------------------------------------------------------
%subst: /omnetpp:://
%#--------------------------------------------------------------------------------------------------------------
%contains: stdout
NClientsEth.r2.ipv6.icmpv6: sending ICMP error: (inet::Packet)Packet Too Big
%#--------------------------------------------------------------------------------------------------------------
%postrun-command: grep "undisposed object:" test.out > test_undisposed.out || true
%not-contains: test_undisposed.out
undisposed object: (
%#--------------------------------------------------------------------------------------------------------------
