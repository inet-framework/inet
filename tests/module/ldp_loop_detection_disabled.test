%description:
Companion to ldp_loop_detection.test (commit C4, RFC 5036 Section 2.8 loop detection):
identical ad hoc 3-LSR triangle topology and routing-loop static configuration
(203.0.113.0/24's next hop cycles LSR1->LSR2->LSR3->LSR1), but with the model's
DEFAULT loopDetection=false, to document/assert what actually happens WITHOUT loop
detection (observed, not assumed -- see below).

Observed behavior: each LSR independently recognizes the looping FEC via its own
static route and (Downstream-on-Demand, distributionMode="dod" as in the sibling
test) sends a Label Request to its own next hop once that session comes up. Exactly
as in the loopDetection=true sibling test, an early session-establishment race can
transiently make an LSR misjudge itself "egress" for the FEC (its own downstream
session not being OPERATIONAL yet is indistinguishable, via findPeerSocket(), from
genuinely having no downstream peer) and reply with a real (wrong) mapping; this
self-corrects via Withdraw once the missing session comes up, which re-triggers a
fresh Label Request downstream (Ldp::updateFecListEntry). Once the full mesh is
OPERATIONAL, this fresh request arrives at a peer that correctly has NO downstream
mapping and is NOT egress -- and, with loopDetection=false, Ldp::processLABEL_REQUEST
just marks it "pending" (RFC 5036 Section 3.5.3) and stops: WITHOUT loop detection,
nothing forwards the request any further downstream, so it never even completes one
lap of the triangle, let alone circulates indefinitely. The request simply sits
permanently pending -- no Notification, no mapping ever installed for this FEC, no
further messages of any kind exchanged for it, and (this being the whole point of
the comparison) no "Loop Detected" line, ever. This is a narrower and less exciting
outcome than the plan's "bounded request/mapping oscillation" hypothesis; what is
actually observed is a single settle-then-stick, which is documented here rather
than the unconfirmed hypothesis (verified by running both configurations and diffing
the number of "203.0.113.0" occurrences: identical up to and including the
post-race resettle, zero afterwards in EITHER configuration -- loopDetection=true's
sibling test additionally propagates that resettled request around the triangle and
catches it three hops later, which is the only difference loopDetection makes here).

Falsification: this file's assertions describe the CURRENT (loopDetection=false
default) behavior and hold on both the parent commit (where the parameter doesn't
exist at all, so the whole "propagate downstream on receiving a pending Label
Request" code path this commit adds is simply absent) and on this commit with
loopDetection left at its default -- i.e. this file exists to pin down and document
the neutral/off behavior, not to falsify against the parent.

%#--------------------------------------------------------------------------------------------------------------
%file: LoopTriangle.ned

import inet.node.mpls.LdpMplsRouter;

//
// Ad hoc 3-LSR triangle, all links directly connected: LSR1 -- LSR2 -- LSR3 -- LSR1.
// See the .test file's %description for the routing-loop static configuration.
//
network LoopTriangle
{
    parameters:
        **.ipv4.configurator.networkConfiguratorModule = "";
    submodules:
        LSR1: LdpMplsRouter {
            @display("p=200,150");
            gates: pppg[2];
        }
        LSR2: LdpMplsRouter {
            @display("p=400,100");
            gates: pppg[2];
        }
        LSR3: LdpMplsRouter {
            @display("p=400,250");
            gates: pppg[2];
        }
    connections:
        LSR1.pppg[0] <--> { delay = 1ms; datarate = 1Mbps; } <--> LSR2.pppg[0];
        LSR2.pppg[1] <--> { delay = 1ms; datarate = 1Mbps; } <--> LSR3.pppg[0];
        LSR3.pppg[1] <--> { delay = 1ms; datarate = 1Mbps; } <--> LSR1.pppg[1];
}

%#--------------------------------------------------------------------------------------------------------------
%# Addressing/router-ids: identical to ldp_loop_detection.test -- see that file's comment.
%file: LSR1.rt
ifconfig:
name: ppp0	inet_addr: 10.0.1.1	MULTICAST	MTU: 1500	Groups: 224.0.0.0	Metric: 1
name: ppp1	inet_addr: 10.0.3.2	MULTICAST	MTU: 1500	Groups: 224.0.0.0	Metric: 1
ifconfigend.

route:
10.0.2.1	10.0.1.2	255.255.255.255	G	0	ppp0
10.0.3.1	10.0.3.1	255.255.255.255	H	0	ppp1
203.0.113.0	10.0.2.1	255.255.255.0	G	0	ppp0

224.0.0.0	*	255.0.0.0	H	0	ppp0
224.0.0.0	*	255.0.0.0	H	0	ppp1
routeend.

%#--------------------------------------------------------------------------------------------------------------
%file: LSR2.rt
ifconfig:
name: ppp0	inet_addr: 10.0.1.2	MULTICAST	MTU: 1500	Groups: 224.0.0.0	Metric: 1
name: ppp1	inet_addr: 10.0.2.1	MULTICAST	MTU: 1500	Groups: 224.0.0.0	Metric: 1
ifconfigend.

route:
10.0.3.2	10.0.1.1	255.255.255.255	G	0	ppp0
10.0.3.1	10.0.2.2	255.255.255.255	G	0	ppp1
203.0.113.0	10.0.3.1	255.255.255.0	G	0	ppp1

224.0.0.0	*	255.0.0.0	H	0	ppp0
224.0.0.0	*	255.0.0.0	H	0	ppp1
routeend.

%#--------------------------------------------------------------------------------------------------------------
%file: LSR3.rt
ifconfig:
name: ppp0	inet_addr: 10.0.2.2	MULTICAST	MTU: 1500	Groups: 224.0.0.0	Metric: 1
name: ppp1	inet_addr: 10.0.3.1	MULTICAST	MTU: 1500	Groups: 224.0.0.0	Metric: 1
ifconfigend.

route:
10.0.2.1	10.0.2.1	255.255.255.255	H	0	ppp0
10.0.3.2	10.0.3.2	255.255.255.255	H	0	ppp1
203.0.113.0	10.0.3.2	255.255.255.0	G	0	ppp1

224.0.0.0	*	255.0.0.0	H	0	ppp0
224.0.0.0	*	255.0.0.0	H	0	ppp1
routeend.

%#--------------------------------------------------------------------------------------------------------------
%inifile: test.ini

[General]
ned-path = .;../../../../src
network = LoopTriangle
sim-time-limit = 10s
total-stack = 64MiB
record-vector-results = false
cmdenv-express-mode = false
cmdenv-event-banners = false
**.ldp.cmdenv-log-level = detail
**.cmdenv-log-level = off
output-scalar-file = "${resultdir}/${configname}-#${runnumber}.sca"

**.LSR1.ipv4.routingTable.routingFile = "LSR1.rt"
**.LSR2.ipv4.routingTable.routingFile = "LSR2.rt"
**.LSR3.ipv4.routingTable.routingFile = "LSR3.rt"

# see ldp_loop_detection.test's identical setting for why this is needed
**.ted.installRoutes = false

**.ppp[*].queue.typename = "DropTailQueue"
**.ppp[*].queue.packetCapacity = 10

**.holdTime = 3s
**.helloInterval = 1s

**.ldp.distributionMode = "dod"
# loopDetection left at its default (false) -- this file's whole point

%#--------------------------------------------------------------------------------------------------------------
%# the request for the looping FEC does get received and correctly recognized as
%# having no downstream mapping (RFC 5036 Section 3.5.3 "pending" handling) --
%# WITHOUT loop detection, this is the end of the line for it: no propagation
%contains: stdout
no mapping for this FEC from the downstream router, marking as pending
%#--------------------------------------------------------------------------------------------------------------
%# loop detection is off: the Notification this feature would send never appears
%not-contains: stdout
Loop Detected
%#--------------------------------------------------------------------------------------------------------------
%# no mapping is ever PERSISTENTLY installed for the looping FEC either -- same
%# "scoped to after the last transient race resettles" reasoning as the sibling
%# test, since an early self-correcting (Withdraw-then-Withdraw) race is expected
%# and legitimate here too (see %description); scope to after the second (last)
%# Mapping Withdraw for this FEC
%postrun-command: awk '/Mapping withdraw received for label=[0-9]+ fec=addr=203\.0\.113\.0/{l=NR} END{print l+1}' test.out > after_withdraw_start.out
%postrun-command: tail -n +$(cat after_withdraw_start.out) test.out > after_last_withdraw.out
%not-contains: after_last_withdraw.out
fec=addr=203.0.113.0
%#--------------------------------------------------------------------------------------------------------------
%postrun-command: grep "undisposed object:" test.out > test_undisposed.out || true
%not-contains: test_undisposed.out
undisposed object: (
%#--------------------------------------------------------------------------------------------------------------
