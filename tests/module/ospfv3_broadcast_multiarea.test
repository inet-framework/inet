%#--------------------------------------------------------------------------------------------------------------
%contains: results/General-#0.sca
scalar Test1.Router6.app[0] packetSent:count 40
%contains: results/General-#0.sca
scalar Test1.Router6.app[0] packetReceived:count 40
%contains: results/General-#0.sca
scalar Test1.Router8.app[0] packetSent:count 40
%contains: results/General-#0.sca
scalar Test1.Router8.app[0] packetReceived:count 40
%#--------------------------------------------------------------------------------------------------------------
%postrun-command: grep "undisposed object:" test.out > test_undisposed.out || true
%not-contains: test_undisposed.out
undisposed object: (
