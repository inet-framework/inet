%description:
Tests TCP keepalive on an idle connection. The client enables keepalive with a
30 s idle time and 5 s probe interval. After the handshake no data flows, so the
client sends a zero-length keepalive probe (seq = snd_una - 1) once the idle time
elapses; the server answers with an ACK and the connection stays open. A second
probe follows one idle period later. The connection is closed normally at t=70s.

%inifile: omnetpp.ini
[General]
record-vector-results = false
ned-path = .;../../../../src;../../lib

network = inet.test.moduletest.lib.TcpTestNet1

sim-time-limit = 80s

cmdenv-event-banners=false
cmdenv-express-mode=false
cmdenv-log-prefix="[%c]: "

*.testing=false

*.tcptester.script=""

# client: keepalive enabled, no data sent, closes at 70s
*.cli_app.active=true
*.cli_app.localAddress="10.0.0.1"
*.cli_app.localPort=1000
*.cli_app.connectAddress="10.0.0.2"
*.cli_app.connectPort=2000
*.cli_app.tOpen=0s
*.cli_app.tSend=-1s
*.cli_app.sendBytes=0B
*.cli_app.sendScript=""
*.cli_app.tClose=70s

# server: passive, no data
*.srv_app.active=false
*.srv_app.localAddress="10.0.0.2"
*.srv_app.localPort=2000
*.srv_app.connectAddress="10.0.0.1"
*.srv_app.connectPort=1000
*.srv_app.tOpen=0s
*.srv_app.tSend=-1s
*.srv_app.sendBytes=0B
*.srv_app.sendScript=""
*.srv_app.tClose=-1s

# tcp settings
*.cli_tcp.keepAliveEnabled=true
*.cli_tcp.keepAliveIdleTime=30s
*.cli_tcp.keepAliveInterval=5s
*.cli_tcp.keepAliveProbeCount=3
*.*_tcp.mss = 500
*.*_tcp.tcpAlgorithmClass = "TcpReno"

%contains: stdout
Keepalive: connection idle, sending probe #1

%contains: stdout
Sending keepalive probe, seq=0

%# first keepalive probe fires one idle period (30 s) after the handshake and is
%# answered by the server; a second probe follows 30 s later.
%contains-regex: stdout
\[30\.005 [^\n]*A\.1000 > B\.2000: A ack 501
%contains-regex: stdout
\[30\.007 [^\n]*A\.1000 < B\.2000: A ack 1
%contains-regex: stdout
\[60\.009 [^\n]*A\.1000 > B\.2000: A ack 501

%# the connection survived keepalive and closed normally with a FIN at t=70
%contains-regex: stdout
\[70\.001 [^\n]*A\.1000 > B\.2000: A F ack 501
