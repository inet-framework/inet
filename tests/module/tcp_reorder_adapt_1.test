%description:
Tests adaptive reordering / dynamic DupThresh (adaptiveReorderingEnabled=true).
Two reordering events of the same magnitude occur. The first is (mis)detected as
loss and spuriously fast-retransmitted; the resulting D-SACK reveals the true
reordering degree, so the sender raises its DupThresh. When a second, equal
reordering event occurs later, the higher DupThresh keeps the sender from
declaring loss again -- no second spurious fast retransmit.

%inifile: omnetpp.ini
[General]
record-vector-results = false
ned-path = .;../../../../src;../../lib

network = inet.test.moduletest.lib.TcpTestNet1

cmdenv-event-banners=false
cmdenv-express-mode=false
cmdenv-log-prefix="[%c]: "

*.testing=false

*.tcptester.script="A5 delay 0.008;A35 delay 0.008"

*.cli_app.active=true
*.cli_app.localAddress="10.0.0.1"
*.cli_app.localPort=1000
*.cli_app.connectAddress="10.0.0.2"
*.cli_app.connectPort=2000
*.cli_app.tOpen=0s
*.cli_app.tSend=0s
*.cli_app.sendBytes=20000B
*.cli_app.sendScript=""
*.cli_app.tClose=-1s

*.srv_app.active=false
*.srv_app.localAddress="10.0.0.2"
*.srv_app.localPort=2000
*.srv_app.connectAddress="10.0.0.1"
*.srv_app.connectPort=1000
*.srv_app.tOpen=0s
*.srv_app.tSend=-1s
*.srv_app.sendBytes=0B
*.srv_app.sendScript=""
*.srv_app.tClose=-1s

*.*_tcp.advertisedWindow = 15000
*.*_tcp.sackSupport = true
*.*_tcp.timestampSupport = false
*.*_tcp.mss = 500
*.*_tcp.tcpAlgorithmClass = "TcpReno"
*.*_tcp.adaptiveReorderingEnabled = true
*.*_tcp.initialWindow = "rfc6928"

include ../../lib/tcp-legacy.ini

%# the reordering degree is learned (grows above the static DupThresh of 3) from
%# the first event, so the later, equal reordering event no longer triggers a
%# spurious fast retransmit.
%# Falsification: with adaptiveReorderingEnabled=false there is no growth line and
%# BOTH events spuriously fast-retransmit (2 "enter Fast Recovery" vs 1 here) --
%# verified during development.
%contains: stdout
reordering degree updated to

%# the transfer completes
%contains: stdout
srv_app: received 20000 bytes
