%description:
Tests IPv6 PIM-SM embedded-RP (RFC 3956) end-to-end: a multicast group in the
FF7x::/12 range carries its rendezvous point address inside the group address, so
PIM-SM derives the RP per group and builds the shared (*,G) tree toward it WITH NO
statically configured RP -- and a real router that OWNS the encoded RP address
actually forwards the multicast stream.

Topology (the same triangle as the examples/pim/sm/ipv6 demo, so the shortest path
from the receiver side to the source does not go through the RP):

    Source --- DR_S ===== RP
                 \\       //
                  \\     //
                   == DR_R --- Receiver

The group is ff7e:140:aaaa:2:66::8, which encodes RIID=1, plen=64, prefix
aaaa:2:66::/64 -- i.e. RP = aaaa:2:66::1. The Ipv6NetworkConfigurator gives RP's
interface toward DR_R exactly that address (prefix aaaa:2:66::/64, address
aaaa:2:66::1), so RP genuinely owns the embedded RP address; every other link gets
an auto-assigned 2001:db8:N::/64 prefix and the configurator's autorouting makes
aaaa:2:66::/64 reachable from everywhere. (DR_S is purely the source's designated
router; the RP sits on the receiver side, so the source's stream reaches the RP
via Register and the RP forwards it down the shared tree.) No pim.RP is configured
anywhere.

Expected: with no static RP, each router warns it will serve only SSM/embedded-RP
groups; DR_R derives the embedded RP and sends Join(*, ff7e:140:aaaa:2:66::8)
toward it; the Source's stream reaches the RP (via Register), the RP forwards it
down the shared tree, and the Receiver actually receives packets.

%#--------------------------------------------------------------------------------------------------------------
%file: test.ned

import inet.networklayer.configurator.ipv6.Ipv6NetworkConfigurator;
import inet.node.ethernet.Eth100M;
import inet.node.ipv6.MulticastRouter6;
import inet.node.ipv6.StandardHost6;

network PimSmEmbeddedRpTest6
{
    submodules:
        Source: StandardHost6;
        DR_S: MulticastRouter6;   // source's designated router
        RP: MulticastRouter6;     // rendezvous point -- owns the embedded RP address
        DR_R: MulticastRouter6;   // receiver's designated router
        Receiver: StandardHost6;
        configurator: Ipv6NetworkConfigurator;
    connections allowunconnected:
        Source.ethg++ <--> Eth100M <--> DR_S.ethg++;
        DR_S.ethg++ <--> Eth100M <--> RP.ethg++;
        DR_S.ethg++ <--> Eth100M <--> DR_R.ethg++; // direct link enabling a distinct SPT
        RP.ethg++ <--> Eth100M <--> DR_R.ethg++;
        DR_R.ethg++ <--> Eth100M <--> Receiver.ethg++;
}

%#--------------------------------------------------------------------------------------------------------------
%inifile: omnetpp.ini

[General]
network = PimSmEmbeddedRpTest6
sim-time-limit = 60s
cmdenv-express-mode = false
cmdenv-log-prefix = "%C: "
ned-path = .;../../../../src

#omnetpp 5.0 - 5.1 compatibility:
eventlog-file = "${resultdir}/${configname}-${runnumber}.elog"
output-scalar-file = "${resultdir}/${configname}-${runnumber}.sca"
output-vector-file = "${resultdir}/${configname}-${runnumber}.vec"
snapshot-file = "${resultdir}/${configname}-${runnumber}.sna"

# RP owns the embedded RP address aaaa:2:66::1 (decoded from the group below) on
# its link toward DR_R; that link uses the encoded prefix aaaa:2:66::/64. Every
# other link gets an auto-assigned unique 2001:db8:N::/64. Autorouting (on by
# default) makes aaaa:2:66::/64 reachable from all routers.
*.configurator.config = xml("<config>\
    <interface hosts='RP'   towards='DR_R' prefix='aaaa:2:66::/64' address='aaaa:2:66::1'/>\
    <interface hosts='DR_R' towards='RP'   prefix='aaaa:2:66::/64'/>\
    <interface hosts='**'                  prefix='2001:db8:x::/64'/>\
    </config>")
**.ipv6.configurator.networkConfiguratorModule = "configurator"

# Sparse mode PIM, MLD on; NO RP configured (embedded-RP needs none).
**.pimConfig = xml("<config><interface mode=\"sparse\"/></config>")
**.ipv6.hasMld = true
**.neighbourDiscovery.dupAddrDetectTransmits = 0

# Source behind DR_S sends to the embedded-RP group; Receiver behind DR_R joins it.
**.Source.numApps = 1
**.Source.app[0].typename = "UdpBasicApp"
**.Source.app[0].destAddresses = "ff7e:140:aaaa:2:66::8"
**.Source.app[0].destPort = 5000
**.Source.app[0].messageLength = 100B
**.Source.app[0].timeToLive = 10
**.Source.app[0].startTime = 20s
**.Source.app[0].sendInterval = 1s
**.Source.app[0].stopTime = 50s

# The Receiver joins at t=0 (default), before the routers exchange PIM Hellos: the
# DR re-resolves the (*,G) upstream neighbor toward the directly-connected RP once
# the adjacency comes up, so the shared tree still builds (see
# IPv6_pimsm_directly_connected_rp).
**.Receiver.numApps = 1
**.Receiver.app[0].typename = "UdpSink"
**.Receiver.app[0].localPort = 5000
**.Receiver.app[0].multicastGroup = "ff7e:140:aaaa:2:66::8"

# Ethernet queues
**.eth[*].queue.typename = "EthernetQosQueue"
**.eth[*].queue.dataQueue.typename = "DropTailQueue"
**.eth[*].queue.dataQueue.packetCapacity = 100

%#--------------------------------------------------------------------------------------------------------------
%subst: /omnetpp:://
%#--------------------------------------------------------------------------------------------------------------
%# no static RP is configured -- only SSM and embedded-RP groups are served
%contains: stdout
no RP address configured; only source-specific (SSM) and embedded-RP
%#--------------------------------------------------------------------------------------------------------------
%# DR_R derives the embedded RP and builds the shared (*,G) tree toward it
%contains: stdout
Sending Join(S=*, G=ff7e:140:aaaa:2:66::8)
%#--------------------------------------------------------------------------------------------------------------
%# the stream is forwarded through the real RP and the Receiver actually receives it
%contains: stdout
Received packet:
%#--------------------------------------------------------------------------------------------------------------
%postrun-command: grep "undisposed object:" test.out > test_undisposed.out || true
%not-contains: test_undisposed.out
undisposed object: (
%#--------------------------------------------------------------------------------------------------------------
