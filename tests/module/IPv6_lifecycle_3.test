%description:

Test crash and restart operations on an IPv6 host while ping6 traffic is active.
Verifies that the crash operation properly cleans up all state without errors,
and that the node can restart afterwards.

%#--------------------------------------------------------------------------------------------------------------
%file: test.ned
import inet.networklayer.configurator.ipv6.Ipv6FlatNetworkConfigurator;
import inet.node.ipv6.Router6;
import inet.node.ipv6.StandardHost6;
import inet.common.scenario.ScenarioManager;
import ned.DatarateChannel;

network IPv6LifecycleTest3
{
    types:
        channel ethline extends DatarateChannel
        {
            delay = 0.1us;
            datarate = 10Mbps;
        }
    submodules:
        scenarioManager: ScenarioManager;
        configurator: Ipv6FlatNetworkConfigurator;
        router: Router6;
        client: StandardHost6;
        server: StandardHost6;
    connections:
        client.ethg++ <--> ethline <--> router.ethg++;
        server.ethg++ <--> ethline <--> router.ethg++;
}
%#--------------------------------------------------------------------------------------------------------------
%inifile: omnetpp.ini
[General]
ned-path = ../../../../src
network = IPv6LifecycleTest3
sim-time-limit = 30s
cmdenv-express-mode = false
cmdenv-log-prefix = "%C: "

#omnetpp 5.0 - 5.1 compatibility:
eventlog-file = "${resultdir}/${configname}-${runnumber}.elog"
output-scalar-file = "${resultdir}/${configname}-${runnumber}.sca"
output-vector-file = "${resultdir}/${configname}-${runnumber}.vec"
snapshot-file = "${resultdir}/${configname}-${runnumber}.sna"

**.hasStatus = true
**.scenarioManager.script = xmldoc("scenario.xml")

# Ping application on client
*.client.numApps = 1
*.client.app[0].typename = "PingApp"
*.client.app[0].destAddr = "server"
*.client.app[0].startTime = 1s
*.client.app[0].sendInterval = 1s

# Ethernet NIC configuration
**.eth[*].queue.typename = "EthernetQosQueue"
**.eth[*].queue.dataQueue.typename = "DropTailQueue"
**.eth[*].queue.dataQueue.packetCapacity = 10

%#--------------------------------------------------------------------------------------------------------------
%file: scenario.xml

<scenario>
    <at t="8.0">
        <crash module="client"/>
    </at>
    <at t="15.0">
        <startup module="client"/>
    </at>
</scenario>

%#--------------------------------------------------------------------------------------------------------------
%subst: /omnetpp:://
%#--------------------------------------------------------------------------------------------------------------
%contains: stdout
IPv6LifecycleTest3.client crashing
%contains: stdout
IPv6LifecycleTest3.client crashed
%contains: stdout
IPv6LifecycleTest3.client starting up
%contains: stdout
IPv6LifecycleTest3.client started
%#--------------------------------------------------------------------------------------------------------------
%not-contains: stdout
<!> Error
%#--------------------------------------------------------------------------------------------------------------
%postrun-command: grep "undisposed object:" test.out > test_undisposed.out || true
%not-contains: test_undisposed.out
undisposed object: (
%#--------------------------------------------------------------------------------------------------------------
