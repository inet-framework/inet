%description:

Checks module interface lookup for various network interface modules.

%file: TestNetwork.ned

import inet.common.MessageDispatcher;
import inet.mobility.static.StationaryMobility;
import inet.linklayer.loopback.LoopbackInterface;
import inet.linklayer.ppp.PppInterface;
import inet.linklayer.ethernet.basic.EthernetInterface;
import inet.linklayer.ethernet.modular.LayeredEthernetInterface;
import inet.linklayer.ieee80211.Ieee80211Interface;
import inet.networklayer.common.InterfaceTable;
import inet.physicallayer.wireless.ieee80211.packetlevel.Ieee80211RadioMedium;

network TestNetwork
{
    parameters:
        *.interfaceTableModule = absPath(".interfaceTable");
        mobility.subjectModule = ".";
        mobility.initialX = 0m;
        mobility.initialY = 0m;
        mobility.initialZ = 0m;
        mobility.initFromDisplayString = false;
        ethernetInterface*.bitrate = 100Mbps;
        ieee80211terface.radio.antenna.mobilityModule = absPath(".mobility");
        @networkNode;
    submodules:
        mobility: StationaryMobility;
        radioMedium: Ieee80211RadioMedium;
        messageDispatcher: MessageDispatcher;
        interfaceTable: InterfaceTable;
        loopbackInterface: LoopbackInterface;
        pppInterface: PppInterface;
        ethernetInterface1: EthernetInterface;
        ethernetInterface2: LayeredEthernetInterface;
        ieee80211terface: Ieee80211Interface;
        test: Test;
    connections allowunconnected:
        messageDispatcher.out++ --> loopbackInterface.upperLayerIn;
        messageDispatcher.out++ --> pppInterface.upperLayerIn;
        messageDispatcher.out++ --> ethernetInterface1.upperLayerIn;
        messageDispatcher.out++ --> ethernetInterface2.upperLayerIn;
        messageDispatcher.out++ --> ieee80211terface.upperLayerIn;
}

%inifile: omnetpp.ini

[General]
network = TestNetwork
ned-path = .;../../../../src
sim-time-limit = 0s

cmdenv-log-prefix = "%>"

#**.queue.typename = "EthernetQosQueue"

%includes
#include "inet/common/IModuleInterfaceLookup.h"
#include "inet/common/ProtocolTag_m.h"
#include "inet/common/packet/Packet.h"
#include "inet/linklayer/common/InterfaceTag_m.h"
#include "inet/queueing/contract/IPassivePacketSink.h"

%activity:
using namespace inet;
using namespace inet::queueing;

#define CHECK(gate, argument) { std::cerr << "interface = " << #gate << ", " << printToStringIfPossible(argument, 0) << " --> " << (findModuleInterface(gate, typeid(IPassivePacketSink), &argument) != nullptr ? "found" : "not found") << std::endl; }

InterfaceReq interfaceReq;
DispatchProtocolReq dispatchProtocolReq;
dispatchProtocolReq.setServicePrimitive(SP_REQUEST);
PacketProtocolTag packetProtocolTag;

auto messageDispatcher = cSimulation::getActiveSimulation()->getSystemModule()->getModuleByPath("messageDispatcher");

auto loopback = messageDispatcher->gate("out", 0);
auto ppp = messageDispatcher->gate("out", 1);
auto ethernetBasic = messageDispatcher->gate("out", 2);
auto ethernetModular = messageDispatcher->gate("out", 3);
auto ieee80211 = messageDispatcher->gate("out", 4);

// loopback interface accepts packets directed to it
interfaceReq.setInterfaceId(100);
CHECK(loopback, interfaceReq);

// PPP network interface accepts PPP service requests (SDUs)
dispatchProtocolReq.setProtocol(&Protocol::ppp);
CHECK(ppp, dispatchProtocolReq);

// Ethernet network interface accepts Ethernet packets (PDUs)
packetProtocolTag.setProtocol(&Protocol::ethernetMac);
CHECK(ethernetBasic, packetProtocolTag);
CHECK(ethernetModular, packetProtocolTag);

// IEEE 802.11 network interface accelts IEEE 802.2 LLC service requests (SDUs)
dispatchProtocolReq.setProtocol(&Protocol::ieee8022llc);
CHECK(ieee80211, dispatchProtocolReq);

// none of the network interfaces accept IPv4 service requests (SDUs)
dispatchProtocolReq.setProtocol(&Protocol::ipv4);
CHECK(loopback, dispatchProtocolReq);
CHECK(ppp, dispatchProtocolReq);
CHECK(ethernetBasic, dispatchProtocolReq);
CHECK(ethernetModular, dispatchProtocolReq);
CHECK(ieee80211, dispatchProtocolReq);

%contains: stderr
interface = loopback, InterfaceReq, interfaceId = 100 --> found
interface = ppp, DispatchProtocolReq, protocol = ppp(52), servicePrimitive = 1 (SP_REQUEST) --> found
interface = ethernetBasic, PacketProtocolTag, protocol = ethernetmac(12), frontOffset = 0 B, backOffset = 0 B --> found
interface = ethernetModular, PacketProtocolTag, protocol = ethernetmac(12), frontOffset = 0 B, backOffset = 0 B --> found
interface = ieee80211, DispatchProtocolReq, protocol = ieee8022llc(33), servicePrimitive = 1 (SP_REQUEST) --> found
interface = loopback, DispatchProtocolReq, protocol = ipv4(38), servicePrimitive = 1 (SP_REQUEST) --> not found
interface = ppp, DispatchProtocolReq, protocol = ipv4(38), servicePrimitive = 1 (SP_REQUEST) --> not found
interface = ethernetBasic, DispatchProtocolReq, protocol = ipv4(38), servicePrimitive = 1 (SP_REQUEST) --> not found
interface = ethernetModular, DispatchProtocolReq, protocol = ipv4(38), servicePrimitive = 1 (SP_REQUEST) --> not found
interface = ieee80211, DispatchProtocolReq, protocol = ipv4(38), servicePrimitive = 1 (SP_REQUEST) --> not found

%#--------------------------------------------------------------------------------------------------------------
%postrun-command: grep "undisposed object:" test.out > test_undisposed.out || true
%not-contains: test_undisposed.out
undisposed object: (
%#--------------------------------------------------------------------------------------------------------------
