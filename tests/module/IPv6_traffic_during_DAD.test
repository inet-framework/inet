%description:
Tests that traffic generated while the source address is tentative (DAD in
progress) is queued and delivered after DAD completes successfully.

A host is configured with a PingApp that starts at t=0, while DAD is still
in progress. The datagram should be queued in pendingDadQueue and sent out
once dadCompleted is signalled.

%#--------------------------------------------------------------------------------------------------------------
%file: test.ned
import inet.networklayer.configurator.ipv6.Ipv6FlatNetworkConfigurator;
import inet.node.ipv6.Router6;
import inet.node.ipv6.StandardHost6;
import ned.DatarateChannel;

network TrafficDuringDadNetwork
{
    types:
        channel ethline extends DatarateChannel
        {
            delay = 0.1us;
            datarate = 10Mbps;
        }
    submodules:
        configurator: Ipv6FlatNetworkConfigurator;
        router: Router6;
        host: StandardHost6;
    connections:
        host.ethg++ <--> ethline <--> router.ethg++;
}
%#--------------------------------------------------------------------------------------------------------------
%inifile: omnetpp.ini
[General]
ned-path = ../../../../src
network = TrafficDuringDadNetwork
sim-time-limit = 10s
cmdenv-express-mode = false
cmdenv-log-prefix = "%C: "

#omnetpp 5.0 - 5.1 compatibility:
eventlog-file = "${resultdir}/${configname}-${runnumber}.elog"
output-scalar-file = "${resultdir}/${configname}-${runnumber}.sca"
output-vector-file = "${resultdir}/${configname}-${runnumber}.vec"
snapshot-file = "${resultdir}/${configname}-${runnumber}.sna"

# Ethernet NIC configuration
**.eth[*].queue.typename = "EthernetQosQueue"
**.eth[*].queue.dataQueue.typename = "DropTailQueue"
**.eth[*].queue.dataQueue.packetCapacity = 10

# PingApp: start immediately (while DAD is still in progress)
**.host.numApps = 1
**.host.app[0].typename = "PingApp"
**.host.app[0].destAddr = "ff02::1"
**.host.app[0].startTime = 0s
**.host.app[0].sendInterval = 10s
**.host.app[0].count = 1

%#--------------------------------------------------------------------------------------------------------------
%subst: /omnetpp:://
%#--------------------------------------------------------------------------------------------------------------
%contains: stdout
Source address is tentative - enqueueing datagram for later resubmission.
%#--------------------------------------------------------------------------------------------------------------
%contains: stdout
DAD completed for address
%#--------------------------------------------------------------------------------------------------------------
%postrun-command: grep "undisposed object:" test.out > test_undisposed.out || true
%not-contains: test_undisposed.out
undisposed object: (
%#--------------------------------------------------------------------------------------------------------------
