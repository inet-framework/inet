%description:

Checks that a router sends Group-Specific and Group-and-Source-Specific Queries
in response to Filter-Mode-Change and Source-List-Change records.
See RFC 3376 6.4.2.

Each such Query is sent [Last Member Query Count] times in total,
[Last Member Query Interval] apart (the initial send plus
lastMemberQueryCount-1 retransmissions). With lastMemberQueryCount=2 and
lastMemberQueryInterval=1s, every Group-/Group-and-Source-Specific Query
below appears twice, 1s apart. The exception at t=8 (TO_IN while in EXCLUDE
mode): the record sends Q(G,X-A) then Q(G); the later Q(G) re-arms the single
per-group retransmission timer, so the Q(G,X-A) is sent only once while the
following Q(G) is the one that gets retransmitted.

%#--------------------------------------------------------------------------------------------------------------

%inifile: omnetpp.ini
[General]
ned-path = .;../../../../src;../../lib
sim-time-limit=100s
cmdenv-express-mode = false
#cmdenv-log-prefix = "%t %N: "

#omnetpp 5.0 - 5.1 compatibility:
eventlog-file = "${resultdir}/${configname}-${runnumber}.elog"
output-scalar-file = "${resultdir}/${configname}-${runnumber}.sca"
output-vector-file = "${resultdir}/${configname}-${runnumber}.vec"
snapshot-file = "${resultdir}/${configname}-${runnumber}.sna"

network = inet.test.moduletest.lib.TestIGMPNetwork
**.igmp.typename = "Igmpv3"
**.IPForward = true
**.multicastForwarding = true

# Pin RNG and the last-member retransmission timers for determinism. With
# lastMemberQueryCount=2 each Group-/Group-and-Source-Specific Query is sent
# twice, lastMemberQueryInterval=1s apart, well within the 100s sim-time.
seed-set = 0
**.igmp.lastMemberQueryInterval = 1s
**.igmp.lastMemberQueryCount = 2

**.scenarioManager.script = xmldoc("scenario.xml")

%#--------------------------------------------------------------------------------------------------------------

%file: scenario.xml
<scenario>

<!-- INCLUDE() -> ALLOW(10.0.0.1,10.0.0.2) -> INCLUDE(10.0.0.1,10.0.0.2) -->
<send t="1" module="node.tester.mac" ifname="eth0" type="Igmpv3Report">
  <record group="225.0.0.1" type="ALLOW" sources="10.0.0.1 10.0.0.2"/>
</send>

<!-- INCLUDE(10.0.0.1,10.0.0.2) -> BLOCK(10.0.0.1) -> INCLUDE(10.0.0.1,10.0.0.2) -->
<send t="2" module="node.tester.mac" ifname="eth0" type="Igmpv3Report">
  <record group="225.0.0.1" type="BLOCK" sources="10.0.0.1"/>
</send>

<!-- INCLUDE(10.0.0.1,10.0.0.2) -> TO_IN(10.0.0.3) -> INCLUDE(10.0.0.1,10.0.0.2,10.0.0.3) -->
<send t="3" module="node.tester.mac" ifname="eth0" type="Igmpv3Report">
  <record group="225.0.0.1" type="TO_IN" sources="10.0.0.3"/>
</send>

<!-- INCLUDE(10.0.0.1,10.0.0.2,10.0.0.3) -> TO_EX(10.0.0.3,10.0.0.4) -> EXCLUDE(10.0.0.3; 10.0.0.4) -->
<send t="4" module="node.tester.mac" ifname="eth0" type="Igmpv3Report">
  <record group="225.0.0.1" type="TO_EX" sources="10.0.0.3 10.0.0.4"/>
</send>

<!-- EXCLUDE(10.0.0.3; 10.0.0.4) -> ALLOW(10.0.0.4) -> EXCLUDE(10.0.0.3;) -->
<send t="5" module="node.tester.mac" ifname="eth0" type="Igmpv3Report">
  <record group="225.0.0.1" type="ALLOW" sources="10.0.0.4"/>
</send>

<!-- EXCLUDE(10.0.0.3;) -> BLOCK(10.0.0.4) -> EXCLUDE(10.0.0.3,10.0.0.4;) -->
<send t="6" module="node.tester.mac" ifname="eth0" type="Igmpv3Report">
  <record group="225.0.0.1" type="BLOCK" sources="10.0.0.4"/>
</send>

<!-- EXCLUDE(10.0.0.3,10.0.0.4;) -> TO_EX(10.0.0.1,10.0.0.3) -> EXCLUDE(10.0.0.1,10.0.0.3;) -->
<send t="7" module="node.tester.mac" ifname="eth0" type="Igmpv3Report">
  <record group="225.0.0.1" type="TO_EX" sources="10.0.0.1 10.0.0.3"/>
</send>

<!-- EXCLUDE(10.0.0.1,10.0.0.3;) -> TO_IN(10.0.0.1,10.0.0.2) -> EXCLUDE(10.0.0.1,10.0.0.2,10.0.0.3;) -->
<send t="8" module="node.tester.mac" ifname="eth0" type="Igmpv3Report">
  <record group="225.0.0.1" type="TO_IN" sources="10.0.0.1 10.0.0.2"/>
</send>

</scenario>

%#--------------------------------------------------------------------------------------------------------------

%#
%# Check that Group-Specific or Group-and-Source-Specific Queries are sent.
%#
%postrun-command: grep "IGMPTester: Received" test.out > tester.out || true
%contains-regex: tester.out
IGMPTester: Received: inet::Igmpv3Query<group=225.0.0.1, sourceList=\(10.0.0.1\),.*>.
IGMPTester: Received: inet::Igmpv3Query<group=225.0.0.1, sourceList=\(10.0.0.1,10.0.0.2\),.*>.
IGMPTester: Received: inet::Igmpv3Query<group=225.0.0.1, sourceList=\(10.0.0.3\),.*>.
IGMPTester: Received: inet::Igmpv3Query<group=225.0.0.1, sourceList=\(10.0.0.4\),.*>.
IGMPTester: Received: inet::Igmpv3Query<group=225.0.0.1, sourceList=\(10.0.0.1,10.0.0.3\),.*>.
IGMPTester: Received: inet::Igmpv3Query<group=225.0.0.1, sourceList=\(10.0.0.3\),.*>.
IGMPTester: Received: inet::Igmpv3Query<group=225.0.0.1, sourceList=\(\),.*>.

%#--------------------------------------------------------------------------------------------------------------
%#
%# Each Group-/Group-and-Source-Specific Query is sent lastMemberQueryCount (=2)
%# times. Reduce every received group query to its source-list and assert the
%# exact ordered sequence: each query content appears twice, except the t=8
%# Q(G,10.0.0.3) which is superseded by the following Q(G) on the shared
%# per-group retransmission timer (see %description).
%#
%postrun-command: grep "IGMPTester: Received" test.out | grep -v "unspec" | sed -E 's/.*sourceList=(\([^)]*\)).*/\1/' > query_sources.out || true
%contains: query_sources.out
(10.0.0.1)
(10.0.0.1)
(10.0.0.1,10.0.0.2)
(10.0.0.1,10.0.0.2)
(10.0.0.3)
(10.0.0.3)
(10.0.0.4)
(10.0.0.4)
(10.0.0.1,10.0.0.3)
(10.0.0.1,10.0.0.3)
(10.0.0.3)
()
()

%#--------------------------------------------------------------------------------------------------------------
%#
%# Check that the retransmission actually fires (RFC 3376 6.4.2).
%#
%postrun-command: grep "Retransmitting Group" test.out > rexmt.out || true
%contains: rexmt.out
Retransmitting Group-and-Source-Specific Query for group '225.0.0.1'
%contains: rexmt.out
Retransmitting Group-Specific Query for group '225.0.0.1'

%#--------------------------------------------------------------------------------------------------------------
%postrun-command: grep "undisposed object:" test.out > test_undisposed.out || true
%not-contains: test_undisposed.out
undisposed object: (
%#--------------------------------------------------------------------------------------------------------------
