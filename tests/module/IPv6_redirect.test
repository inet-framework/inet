%description:
Tests ICMPv6 Redirect sending and processing (RFC 4861 Section 8).

Topology: H1 and two routers (R1, R2) on the same link (switch1).
A server (srv) is on a separate link behind R2.

The flat network configurator creates inter-router routes. Because both
R1 and R2 are on the same switch, some of these routes result in a
router forwarding a packet back out on the same interface it arrived on
(e.g. R2 routes packets for R1's prefix via R1 on switch1, and R1 routes
packets for R2's prefix via R2 on switch1). This triggers ICMPv6
Redirect messages telling the other router to send directly.

We verify that: (1) a Redirect is sent, (2) a Redirect is received and
processed, (3) UDP traffic from H1 reaches srv, and (4) no undisposed
objects remain at simulation end.

%#--------------------------------------------------------------------------------------------------------------
%file: test.ned
import inet.networklayer.configurator.ipv6.Ipv6FlatNetworkConfigurator;
import inet.node.ethernet.EthernetSwitch;
import inet.node.ipv6.Router6;
import inet.node.ipv6.StandardHost6;
import ned.DatarateChannel;

network RedirectTestNetwork
{
    types:
        channel ethline extends DatarateChannel
        {
            delay = 0.1us;
            datarate = 10Mbps;
        }
    submodules:
        configurator: Ipv6FlatNetworkConfigurator;
        switch1: EthernetSwitch;
        R1: Router6;
        R2: Router6;
        H1: StandardHost6;
        srv: StandardHost6;
    connections:
        H1.ethg++ <--> ethline <--> switch1.ethg++;
        R1.ethg++ <--> ethline <--> switch1.ethg++;
        R2.ethg++ <--> ethline <--> switch1.ethg++;
        R2.ethg++ <--> ethline <--> srv.ethg++;
}
%#--------------------------------------------------------------------------------------------------------------
%inifile: omnetpp.ini
[General]
ned-path = ../../../../src
network = RedirectTestNetwork
sim-time-limit = 20s
cpu-time-limit = 5s
cmdenv-express-mode = false
cmdenv-log-prefix = "%C: "

#omnetpp 5.0 - 5.1 compatibility:
eventlog-file = "${resultdir}/${configname}-${runnumber}.elog"
output-scalar-file = "${resultdir}/${configname}-${runnumber}.sca"
output-vector-file = "${resultdir}/${configname}-${runnumber}.vec"
snapshot-file = "${resultdir}/${configname}-${runnumber}.sna"

# udp apps: H1 sends to srv
**.H1.numApps = 1
**.H1.app[0].typename = "UdpBasicApp"
**.H1.app[0].destAddresses = "srv"
**.H1.app[0].destPort = 1000
**.H1.app[0].messageLength = 64B
**.H1.app[0].startTime = 10s
**.H1.app[0].stopTime = 15s
**.H1.app[0].sendInterval = 2s

**.srv.numApps = 1
**.srv.app[0].typename = "UdpSink"
**.srv.app[0].localPort = 1000

# Ethernet NIC configuration
**.eth[*].queue.typename = "EthernetQosQueue"
**.eth[*].queue.dataQueue.typename = "DropTailQueue"
**.eth[*].queue.dataQueue.packetCapacity = 10

%#--------------------------------------------------------------------------------------------------------------
%subst: /omnetpp:://
%#--------------------------------------------------------------------------------------------------------------
%contains: stdout
Sending ICMPv6 Redirect to
%#--------------------------------------------------------------------------------------------------------------
%contains: stdout
Received ICMPv6 Redirect from
%#--------------------------------------------------------------------------------------------------------------
%contains: stdout
RedirectTestNetwork.srv.app[0]: Received packet: (inet::Packet)UdpBasicAppData-0 (64 B)
%#--------------------------------------------------------------------------------------------------------------
%postrun-command: grep "undisposed object:" test.out > test_undisposed.out || true
%not-contains: test_undisposed.out
undisposed object: (
%#--------------------------------------------------------------------------------------------------------------
