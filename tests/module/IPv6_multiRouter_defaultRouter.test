%description:
Tests that an IPv6 host with multiple default routers on the same link
can successfully communicate. The host receives Router Advertisements
from both routers, adds both to its default router list, selects one,
and sends traffic through it.

Inline network: host and two routers on the same Ethernet switch.
A server is behind R2. The flat configurator sets up routes between
routers, so traffic can flow via either R1->R2->srv or R2->srv.

%#--------------------------------------------------------------------------------------------------------------
%file: test.ned
import inet.networklayer.configurator.ipv6.Ipv6FlatNetworkConfigurator;
import inet.node.ethernet.EthernetSwitch;
import inet.node.ipv6.Router6;
import inet.node.ipv6.StandardHost6;
import ned.DatarateChannel;

network MultiRouterNetwork
{
    types:
        channel ethline extends DatarateChannel
        {
            delay = 0.1us;
            datarate = 10Mbps;
        }
    submodules:
        configurator: Ipv6FlatNetworkConfigurator;
        switch: EthernetSwitch;
        R1: Router6;
        R2: Router6;
        host: StandardHost6;
        srv: StandardHost6;
    connections:
        host.ethg++ <--> ethline <--> switch.ethg++;
        R1.ethg++ <--> ethline <--> switch.ethg++;
        R2.ethg++ <--> ethline <--> switch.ethg++;
        R2.ethg++ <--> ethline <--> srv.ethg++;
}
%#--------------------------------------------------------------------------------------------------------------
%inifile: omnetpp.ini
[General]
ned-path = ../../../../src
network = MultiRouterNetwork
sim-time-limit = 15s
cmdenv-express-mode = false
cmdenv-log-prefix = "%C: "

#omnetpp 5.0 - 5.1 compatibility:
eventlog-file = "${resultdir}/${configname}-${runnumber}.elog"
output-scalar-file = "${resultdir}/${configname}-${runnumber}.sca"
output-vector-file = "${resultdir}/${configname}-${runnumber}.vec"
snapshot-file = "${resultdir}/${configname}-${runnumber}.sna"

# udp apps
**.host.numApps = 1
**.host.app[0].typename = "UdpBasicApp"
**.host.app[0].destAddresses = "srv"
**.host.app[0].destPort = 1000
**.host.app[0].messageLength = 64B
**.host.app[0].startTime = 10s
**.host.app[0].stopTime = 11s
**.host.app[0].sendInterval = 10s

**.srv.numApps = 1
**.srv.app[0].typename = "UdpSink"
**.srv.app[0].localPort = 1000

# Ethernet NIC configuration
**.eth[*].queue.typename = "EthernetQosQueue"
**.eth[*].queue.dataQueue.typename = "DropTailQueue"
**.eth[*].queue.dataQueue.packetCapacity = 10

%#--------------------------------------------------------------------------------------------------------------
%subst: /omnetpp:://
%#--------------------------------------------------------------------------------------------------------------
%contains: stdout
MultiRouterNetwork.host.ipv6.neighbourDiscovery: RA's router lifetime is non-zero, creating an entry in the Host's default router list with lifetime=
%#--------------------------------------------------------------------------------------------------------------
%contains: stdout
MultiRouterNetwork.srv.app[0]: Received packet: (inet::Packet)UdpBasicAppData-0 (64 B)
%#--------------------------------------------------------------------------------------------------------------
%postrun-command: grep "undisposed object:" test.out > test_undisposed.out || true
%not-contains: test_undisposed.out
undisposed object: (
%#--------------------------------------------------------------------------------------------------------------
