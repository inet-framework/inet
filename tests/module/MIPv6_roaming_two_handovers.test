%description:
A single mobile node roams across THREE access networks -- its home network and two
foreign networks -- performing two successive handovers (AP_Home -> AP_1 -> AP_2). In each
foreign network it forms a new care-of address and re-registers it, and it re-runs the
return routability / route optimization procedure with the correspondent node so the CN's
route-optimized traffic follows it to the new care-of address.

This is a regression test for the second-handover return-routability bug: the care-of
keygen token (and its CoTI rate-limit timestamp) is bound to a care-of address, so on the
SECOND handover the mobile node must send a fresh CoTI for the new CoA. Previously the stale
rate-limit timestamp suppressed that CoTI, return routability never completed, the CN's
binding was never updated, and the CN's pings blackholed to the first (now stale) care-of
address. The test asserts that the CN keeps receiving ping replies well after the second
handover (a high ping sequence number), which only happens once route optimization is
correctly redone for the second care-of address.

%#--------------------------------------------------------------------------------------------------------------
%inifile: omnetpp.ini
[General]
ned-path = .;../../../../src;../../lib
network = inet.test.moduletest.lib.Mipv6RoamingNetwork
sim-time-limit = 90s
cmdenv-express-mode = false
cmdenv-log-prefix = "%C: "
num-rngs = 3
seed-set = 1
**.mobility.rng-0 = 2

*.total_mn = 1
*.total_cn = 1

**.neighbourDiscovery.minIntervalBetweenRAs = 0.03s
**.neighbourDiscovery.maxIntervalBetweenRAs = 0.07s
**.neighbourDiscovery.detectL2Movement = false

*.radioMedium.mediumLimitCache.maxTransmissionPower = 2.0mW
*.radioMedium.mediumLimitCache.minReceptionPower = -82dBm
*.radioMedium.mediumLimitCache.minInterferencePower = -82dBm

**.wlan*.mgmt.numAuthSteps = 4
**.AP*.wlan*.mgmt.beaconInterval = 0.1s
**.AP_Home.wlan*.mgmt.ssid = "HOME"
**.AP_Home.wlan*.address = "10:AA:00:00:00:01"
**.AP_Home.eth[0].address = "10:AE:00:00:00:02"
**.AP_Home.eth[0].duplexMode = true
**.AP_1.wlan*.mgmt.ssid = "AP1"
**.AP_1.wlan*.address = "10:AA:00:00:A1:01"
**.AP_1.eth[0].address = "10:AE:00:00:A1:02"
**.AP_1.eth[0].duplexMode = true
**.AP_2.wlan*.mgmt.ssid = "AP2"
**.AP_2.wlan*.address = "10:AA:00:00:A2:01"
**.AP_2.eth[0].address = "10:AE:00:00:A2:02"
**.AP_2.eth[0].duplexMode = true

**.mobility.constraintAreaMinZ = 0m
**.mobility.constraintAreaMaxZ = 0m
**.MN[0].mobility.typename = "RectangleMobility"
**.MN[0].mobility.constraintAreaMinX = 180m
**.MN[0].mobility.constraintAreaMinY = 170m
**.MN[0].mobility.constraintAreaMaxX = 950m
**.MN[0].mobility.constraintAreaMaxY = 180m
**.MN[0].mobility.startPos = 0
**.MN[0].mobility.speed = 10mps
**.MN*.mobility.updateInterval = 0.1s

# CN pings the MN's home address throughout; the replies must follow the MN across both handovers
**.MN*.numApps = 0
**.CN*.numApps = 1
**.CN*.app[*].typename = "PingApp"
**.CN[0].app[0].destAddr = "aaaa:0:66:0:8aa:ff:fe00:b"
**.CN*.app[0].packetSize = 56B
**.CN*.app[0].sendInterval = 0.5s
**.CN[0].app[0].startTime = 1s
**.CN*.app[0].hopLimit = 32
**.CN*.app[0].printPing = true

**.forwarding = false
**.eth[*].queue.typename = "EthernetQosQueue"
**.eth[*].queue.dataQueue.typename = "DropTailQueue"
**.eth[*].queue.dataQueue.packetCapacity = 10
**.eth*.duplexMode = true
**.analogModel.ignorePartialInterference = true
**.AP_Home.wlan*.radio.channelNumber = 1
**.AP_1.wlan*.radio.channelNumber = 2
**.AP_2.wlan*.radio.channelNumber = 3
**.MN*.wlan*.radio.channelNumber = 0
**.wlan*.agent.activeScan = true
**.wlan*.agent.defaultSsid = ""
**.wlan*.agent.channelsToScan = "1 2 3"
**.wlan*.agent.probeDelay = 0.1s
**.wlan*.agent.minChannelTime = 0.15s
**.wlan*.agent.maxChannelTime = 0.3s
**.wlan*.agent.authenticationTimeout = 5s
**.wlan*.agent.associationTimeout = 5s
**.wlan*.bitrate = 2Mbps
**.wlan*.mac.dcf.channelAccess.cwMin = 7
**.radio.transmitter.power = 2.0mW
**.constraintAreaMinX = 0m
**.constraintAreaMinY = 0m
**.constraintAreaMaxX = 1050m
**.constraintAreaMaxY = 850m

#omnetpp 5.0 - 5.1 compatibility:
eventlog-file = "${resultdir}/${configname}-${runnumber}.elog"
output-scalar-file = "${resultdir}/${configname}-${runnumber}.sca"
output-vector-file = "${resultdir}/${configname}-${runnumber}.vec"
snapshot-file = "${resultdir}/${configname}-${runnumber}.sna"

%#--------------------------------------------------------------------------------------------------------------
%subst: /omnetpp:://
%#--------------------------------------------------------------------------------------------------------------
%contains: stdout
Mipv6RoamingNetwork.MN[0].ipv6.mipv6: Binding was accepted.
%#--------------------------------------------------------------------------------------------------------------
%# Connectivity must survive the SECOND handover: ping reply #160 (sent at ~t=81s, long
%# after the AP_1 -> AP_2 handover near t=64s) only arrives once route optimization is
%# correctly redone for the second care-of address. With the second-handover RR bug the
%# correspondent node's binding stays stale, replies stop shortly after the handover, and
%# this high-sequence reply never appears.
%contains: stdout
Mipv6RoamingNetwork.CN[0].app[0]: Ping reply #160 arrived
%#--------------------------------------------------------------------------------------------------------------
%postrun-command: grep "undisposed object:" test.out > test_undisposed.out || true
%not-contains: test_undisposed.out
undisposed object: (
%#--------------------------------------------------------------------------------------------------------------
