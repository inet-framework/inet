%description:
Remaining TCP_INFO fields, continued: `probes` (cumulative zero-window
persist probes). tcp_info_fields_1.test's RTO scenario never exercises this
counter (it stays 0 there). Reuses tcp_persist_1.test's exact zero-window
scenario (client sends more than the receiver's advertised window, server
never reads -> zero window -> persist timer), which that test's own pinned
trace shows firing probes at t=6.013, 11.013 and 16.013 -- queries status
right after the first two to confirm the counter increments exactly once
per probe, not once per persist-timer tick or some other miscount.

Falsification: none needed as a separate run -- probes reads 1 then 2, not
some fixed value both times, which a stub or an off-by-one (e.g. counting
timer restarts instead of actual probe sends) would be unlikely to reproduce
exactly.

%inifile: omnetpp.ini
[General]
record-vector-results = false
ned-path = .;../../../../src;../../lib

network = inet.test.moduletest.lib.TcpTestNet1

sim-time-limit = 20s

cmdenv-event-banners=false
cmdenv-express-mode=false
cmdenv-log-prefix="[%c]: "

*.testing=false

*.tcptester.script=""

*.cli_app.active=true
*.cli_app.localAddress="10.0.0.1"
*.cli_app.localPort=1000
*.cli_app.connectAddress="10.0.0.2"
*.cli_app.connectPort=2000
*.cli_app.tOpen=0s
*.cli_app.tSend=1s
*.cli_app.sendBytes=20000B
*.cli_app.sendScript=""
*.cli_app.tClose=-1s
# Just after the 1st (t=6.013) and 2nd (t=11.013) persist probes pinned by
# tcp_persist_1.test's own trace.
*.cli_app.statusRequestScript="6.5,11.5"

*.srv_app.active=false
*.srv_app.localAddress="10.0.0.2"
*.srv_app.localPort=2000
*.srv_app.connectAddress="10.0.0.1"
*.srv_app.connectPort=1000
*.srv_app.tOpen=0s
*.srv_app.tSend=-1s
*.srv_app.sendBytes=0B
*.srv_app.sendScript=""
*.srv_app.tClose=-1s
*.srv_app.autoRead=false

*.*_tcp.advertisedWindow = 3000
*.*_tcp.delayedAcksEnabled = false
*.*_tcp.nagleEnabled = true
*.*_tcp.sackSupport = false
*.*_tcp.windowScalingSupport = false
*.*_tcp.timestampSupport = false
*.*_tcp.mss = 500
*.*_tcp.tcpAlgorithmClass = "TcpReno"

include ../../lib/tcp-legacy.ini

%#--------------------------------------------------------------------------------------------------------------
%contains: stdout
STATUS: caState=0 backoff=0 lost=4294967295 probes=1 bytesReceived=0 deliveredCePkts=0 deliveredCeBytes=0
%#--------------------------------------------------------------------------------------------------------------
%contains: stdout
STATUS: caState=0 backoff=2 lost=4294967295 probes=2 bytesReceived=0 deliveredCePkts=0 deliveredCeBytes=0
%#--------------------------------------------------------------------------------------------------------------
%postrun-command: grep "undisposed object:" test.out > test_undisposed.out || true
%not-contains: test_undisposed.out
undisposed object: (
%#--------------------------------------------------------------------------------------------------------------
