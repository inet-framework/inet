%description:
802.11g ERP-OFDM mandatory rate 6 Mbps: data frame uses ERP-OFDM at 6 Mbps. [Required]

%file: G_MandatoryRates.cc

#include "ProtocolTest.h"
#include "WifiTestSupport.h"

namespace inet {
namespace protocoltest {

// 6 Mbps is the lowest mandatory 802.11g ERP-OFDM rate (also interoperable with 11a).
Define_ProtocolTest(wifi_11g_mandatory_rates)
{
    return ProtocolTest("wifi_11g_mandatory_rates")
        .once(on("sta1.wlan[0].mac").signal("packetSentToLower")
                  .packet("ieee80211mac.type == 32 || ieee80211mac.type == 40")
                  .match([](const MatchContext& c) {
                      return isErpOfdm(c.event) &&
                             std::abs(txNetBitrateMbps(c.event) - 6.0) < 0.1;
                  })
                  .describe("a data frame in ERP-OFDM mode at 6 Mbps").within(2.5));
}

} // namespace protocoltest
} // namespace inet

%inifile: test.ini

[General]
*.tester.testName = "wifi_11g_mandatory_rates"
*.sta*.wlan[*].mac.*.rateSelection.dataFrameBitrate = 6Mbps
*.ap.wlan[*].mac.*.rateSelection.dataFrameBitrate = 6Mbps
include ../../ini/_g.ini
include ../../ini/_base.ini

%contains: stdout
PROTOCOLTEST wifi_11g_mandatory_rates: PASS
