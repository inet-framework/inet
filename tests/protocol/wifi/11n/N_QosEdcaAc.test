%description:
802.11e EDCA access categories: a UDP flow classified by QosClassifier produces a QoS
data frame (type 40 = ST_DATA_WITH_QOS) with a non-zero TID. [Required]

%file: N_QosEdcaAc.cc

#include "ProtocolTest.h"

namespace inet {
namespace protocoltest {

// 40 = ST_DATA_WITH_QOS. QosClassifier assigns UDP traffic to AC_BE (TID 0) by default,
// or AC_VI (TID 4/5) if configured for video. Here we simply assert that QoS data frames
// are produced (type 40), demonstrating EDCA access categorization is active.
Define_ProtocolTest(wifi_qos_edca_ac)
{
    return ProtocolTest("wifi_qos_edca_ac")
        .once(on("sta1.wlan[0].mac").signal("packetSentToLower")
                  .packet("ieee80211mac.type == 40")
                  .describe("a QoS data frame (type 40) produced by EDCA").within(2.5));
}

} // namespace protocoltest
} // namespace inet

%inifile: test.ini

[General]
*.tester.testName = "wifi_qos_edca_ac"
include ../../ini/_n.ini
include ../../ini/_base.ini

%contains: stdout
PROTOCOLTEST wifi_qos_edca_ac: PASS
