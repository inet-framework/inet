%description:
802.11n HCF RTS/CTS exchange followed by QoS data and BlockAck or ACK. [Required]

%file: N_RtsCts.cc

#include "ProtocolTest.h"

namespace inet {
namespace protocoltest {

// 27=RTS, 28=CTS, 40=QoS data, 29=ACK (or 25=BlockAck if block ack is active).
Define_ProtocolTest(wifi_11n_rts_cts)
{
    return ProtocolTest("wifi_11n_rts_cts")
        .once(on("sta1.wlan[0].mac").signal("packetSentToLower")
                  .packet("ieee80211mac.type == 27")
                  .describe("an RTS frame from sta1").within(2.5))
        .once(on("sta1.wlan[0].mac").signal("packetReceivedFromLower")
                  .packet("ieee80211mac.type == 28")
                  .describe("a CTS response").within(0.02))
        .once(on("sta1.wlan[0].mac").signal("packetSentToLower")
                  .packet("ieee80211mac.type == 40")
                  .describe("the QoS data frame").within(0.02))
        .once(on("sta1.wlan[0].mac").signal("packetReceivedFromLower")
                  .packet("ieee80211mac.type == 29 || ieee80211mac.type == 25")
                  .describe("ACK or BlockAck").within(0.02));
}

} // namespace protocoltest
} // namespace inet

%inifile: test.ini

[General]
*.tester.testName = "wifi_11n_rts_cts"
**.wlan[*].mac.hcf.rtsPolicy.rtsThreshold = 100B
include ../../ini/_n.ini
include ../../ini/_base.ini

%contains: stdout
PROTOCOLTEST wifi_11n_rts_cts: PASS
