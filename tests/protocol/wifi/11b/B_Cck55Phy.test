%description:
802.11b HR/DSSS-CCK 5.5 Mbps PHY mode. [Required]

Force bitrate to 5.5 Mbps; the selected mode must be an HR/DSSS mode (isHrDsss).

%file: B_Cck55Phy.cc

#include "ProtocolTest.h"
#include "WifiTestSupport.h"

namespace inet {
namespace protocoltest {

Define_ProtocolTest(wifi_11b_cck55_phy)
{
    return ProtocolTest("wifi_11b_cck55_phy")
        .once(on("sta1.wlan[0].mac").signal("packetSentToLower")
                  .packet("ieee80211mac.type == 32 || ieee80211mac.type == 40")
                  .match([](const MatchContext& c) { return isHrDsss(c.event); })
                  .describe("a data frame in HR/DSSS-CCK 5.5 Mbps mode").within(2.5));
}

} // namespace protocoltest
} // namespace inet

%inifile: test.ini

[General]
*.tester.testName = "wifi_11b_cck55_phy"
*.sta*.wlan[*].bitrate = 5.5Mbps
*.ap.wlan[*].bitrate = 5.5Mbps
include ../../ini/_b.ini
include ../../ini/_base.ini

%contains: stdout
PROTOCOLTEST wifi_11b_cck55_phy: PASS
