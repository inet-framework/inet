%description:
802.11 legacy fragmentation: a data frame is sent with moreFragments == true when the
payload exceeds the fragmentationThreshold. [Required]

Set fragmentationThreshold to 200 B; the 1000 B payload is split into fragments, the
first of which carries moreFragments = true.

%file: Legacy_Fragmentation.cc

#include "ProtocolTest.h"

namespace inet {
namespace protocoltest {

// 32 = ST_DATA (non-QoS). The first fragment has moreFragments == true.
Define_ProtocolTest(wifi_legacy_fragmentation)
{
    return ProtocolTest("wifi_legacy_fragmentation")
        .once(on("sta1.wlan[0].mac").signal("packetSentToLower")
                  .packet("ieee80211mac.type == 32 && ieee80211mac.moreFragments == true")
                  .describe("a data fragment with moreFragments == true").within(2.5));
}

} // namespace protocoltest
} // namespace inet

%inifile: test.ini

[General]
*.tester.testName = "wifi_legacy_fragmentation"
# 200 B threshold splits the 1000 B message into multiple fragments.
**.wlan[*].mac.dcf.originatorMacDataService.fragmentationPolicy.fragmentationThreshold = 200B
include ../../ini/_legacy.ini
include ../../ini/_base.ini

%contains: stdout
PROTOCOLTEST wifi_legacy_fragmentation: PASS
