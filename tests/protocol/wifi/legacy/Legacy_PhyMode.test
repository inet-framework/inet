%description:
802.11-1997 legacy DSSS PHY (1 Mbps). [Required]

%file: Legacy_PhyMode.cc

#include "ProtocolTest.h"
#include "WifiTestSupport.h"

namespace inet {
namespace protocoltest {

Define_ProtocolTest(wifi_legacy_dsss_phy)
{
    return ProtocolTest("wifi_legacy_dsss_phy")
        .once(on("sta1.wlan[0].mac").signal("packetSentToLower")
                  .packet("ieee80211mac.type == 32 || ieee80211mac.type == 40")
                  .match([](const MatchContext& c) { return isDsss(c.event); })
                  .describe("a data frame transmitted in DSSS mode").within(2.5));
}

} // namespace protocoltest
} // namespace inet

%inifile: test.ini

[General]
*.tester.testName = "wifi_legacy_dsss_phy"
include ../../ini/_legacy.ini
include ../../ini/_base.ini

%contains: stdout
PROTOCOLTEST wifi_legacy_dsss_phy: PASS
