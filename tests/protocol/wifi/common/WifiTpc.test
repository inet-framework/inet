%description:
802.11h TPC (Transmit Power Control): a TPC Report action frame (type 13) or a Power
Constraint IE in a Beacon indicates power-level management. [NOT-MODELED -- INET's DFS/
Channel Switch test (WifiDfsChannelSwitch) already confirms 802.11h is not modeled;
no TPC Report action or Power Constraint IE is generated by the AP]

%file: WifiTpc.cc

#include "ProtocolTest.h"

namespace inet {
namespace protocoltest {

// Spec assertion: AP sends a TPC Report action frame (type 13, category Spectrum Mgmt)
// or includes a Power Constraint IE in its Beacons. INET has no 802.11h TPC module.
Define_ProtocolTest(wifi_tpc)
{
    return ProtocolTest("wifi_tpc")
        .once(on("ap.wlan[0].mac").signal("packetSentToLower")
                  .packet("ieee80211mac.type == 13 && Ieee80211TpcReport.length >= 0")
                  .describe("a TPC Report action frame from AP").within(2.5));
}

} // namespace protocoltest
} // namespace inet

%inifile: test.ini

[General]
*.tester.testName = "wifi_tpc"
include ../../ini/_a.ini
include ../../ini/_base.ini

%contains: stdout
PROTOCOLTEST wifi_tpc: FAIL
