%description:

Protocol Test Framework -- self-contained fault-injection test (MITM, network included).

The network below splices a PacketTap onto the wire but has NO tester. The program drives
the tap to drop host1's first TCP data segment, then asserts host1 retransmits the same
segment (same sequence number) after the RTO. A ProtocolTester is attached to the network
at runtime.

%includes:
#include "ProtocolTest.h"

%global:

using namespace inet;
using namespace inet::protocoltest;

Define_ProtocolTestProgram()
{
    return ProtocolTest("tcp_retransmit")
        // the tap drops the first data-bearing segment to host2's port (not the SYN/ACKs).
        .intercept(intercept("tap")
                     .match("tcp.destPort == 1000 && tcp.synBit == false").minBytes(100).nth(1)
                     .drop().describe("the first data segment"))
        // host1 sends the data segment after the handshake; remember its sequence number.
        .once(on("host1.tcp").signal("packetSentToLower")
                  .packet("tcp.destPort == 1000 && tcp.synBit == false").after(0.15)
                  .capture("dataSeq", "tcp.sequenceNo").describe("the data segment").within(0.3))
        // the tap dropped it, so host1 retransmits the same segment after the RTO.
        .once(on("host1.tcp").signal("packetSentToLower")
                  .packet("tcp.sequenceNo == {dataSeq} && tcp.synBit == false").notBefore(0.3)
                  .describe("the retransmitted data segment").within(5.0));
}

%activity:
// present only so opp_test compiles the %global above; this module is not in the network.
EV << "tcp_retransmit compiled\n";

%file: test.ned

import inet.node.inet.StandardHost;
import inet.node.ethernet.Eth100M;
import inet.networklayer.configurator.ipv4.Ipv4NetworkConfigurator;
import inet.protocoltest.PacketTap;

// Two hosts with a PacketTap spliced on the link -- note: NO tester (attached at runtime).
network RetransmitNet
{
    submodules:
        configurator: Ipv4NetworkConfigurator { @display("p=100,50"); }
        host1: StandardHost { @display("p=300,100"); }
        tap: PacketTap { @display("p=400,100"); }
        host2: StandardHost { @display("p=500,100"); }
    connections:
        host1.ethg++ <--> Eth100M <--> tap.a;
        tap.b       <--> Eth100M <--> host2.ethg++;
}

%inifile: omnetpp.ini

[General]
network = RetransmitNet
sim-time-limit = 8s
seed-set = 0

*.host1.numApps = 1
*.host1.app[0].typename = "TcpSessionApp"
*.host1.app[0].connectAddress = "host2"
*.host1.app[0].connectPort = 1000
*.host1.app[0].tOpen = 0.1s
*.host1.app[0].tSend = 0.2s
*.host1.app[0].sendBytes = 100B
*.host1.app[0].tClose = -1s
*.host2.numApps = 1
*.host2.app[0].typename = "TcpEchoApp"
*.host2.app[0].localPort = 1000
*.host*.ipv4.arp.typename = "GlobalArp"

%contains: stdout
PROTOCOLTEST tcp_retransmit: PASS
