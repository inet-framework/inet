%description:
The Local Mobility Anchor answers with a Proxy Binding Acknowledgement. [Required -- RFC 5213 6.9.2]

On accepting a Proxy Binding Update, the LMA sets up its binding cache entry and the bi-directional
tunnel to the MAG, and replies with a Proxy Binding Acknowledgement -- a Binding Acknowledgement
with the Proxy-Registration (P) flag set. Observed on the wire at mag1's backhaul interface as it
receives the acknowledgement from the LMA.

%file: Pmipv6_ProxyBindingAck.cc

#include "ProtocolTest.h"

namespace inet {
namespace protocoltest {

Define_ProtocolTest(ipv6_pmipv6_proxy_binding_ack)
{
    return ProtocolTest("ipv6_pmipv6_proxy_binding_ack")
        .once(on("mag1.eth[0].mac").signal("packetReceivedFromLower")
                  .packet("BindingAcknowledgement.proxyRegistrationFlag == true")
                  .describe("the LMA's Proxy Binding Acknowledgement to mag1").within(8));
}

} // namespace protocoltest
} // namespace inet

%inifile: test.ini

[General]
*.tester.testName = "ipv6_pmipv6_proxy_binding_ack"
include ../../ini/_pmipv6.ini

%contains: stdout
PROTOCOLTEST ipv6_pmipv6_proxy_binding_ack: PASS
