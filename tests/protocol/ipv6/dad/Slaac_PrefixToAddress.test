%description:
SLAAC forms the global address from the advertised prefix. [Required -- RFC 4862 5.5.3]

The correctness tie between Router Advertisement and autoconfiguration: the global address
a host runs DAD for must lie within the on-link prefix the router advertises
(2001:db8:1:1::/64). Observed on the wire as host1 transmits a global DAD probe whose target
address matches the advertised prefix.

%file: Slaac_PrefixToAddress.cc

#include "ProtocolTest.h"
#include "Ipv6TestSupport.h"

namespace inet {
namespace protocoltest {

Define_ProtocolTest(ipv6_slaac_prefix_to_address)
{
    return ProtocolTest("ipv6_slaac_prefix_to_address")
        .once(on("host1.eth[0].mac").signal("packetSentToLower")
                  .match([](const MatchContext& c) {
                      return isDadProbe(c.event)
                             && nsTarget(c.event).matches(Ipv6Address("2001:db8:1:1::"), 64);
                  })
                  .describe("a DAD probe whose target lies within the advertised prefix")
                  .within(4.0));
}

} // namespace protocoltest
} // namespace inet

%inifile: test.ini

[General]
*.tester.testName = "ipv6_slaac_prefix_to_address"
include ../../ini/_base.ini

%contains: stdout
PROTOCOLTEST ipv6_slaac_prefix_to_address: PASS
