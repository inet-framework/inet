%description:
Packet Too Big carries the next-hop link MTU. [Required -- RFC 4443 3.2; NOT-MODELED]

The whole point of Packet Too Big is Path MTU Discovery: the message MUST report the MTU of the
next-hop link that could not be traversed, so the source can shrink its packets to that size.
INET generates the message but leaves the MTU field zero (a `// TODO set MTU` in Ipv6.cc), so the
faithful assertion that the reported MTU equals the reduced next-hop MTU (1280) fails -- PMTUD
cannot actually converge on the right size.

%file: Icmpv6_PacketTooBigMtu.cc

#include "ProtocolTest.h"

namespace inet {
namespace protocoltest {

Define_ProtocolTest(ipv6_icmpv6_packet_too_big_mtu)
{
    return ProtocolTest("ipv6_icmpv6_packet_too_big_mtu")
        .once(on("host1.eth[0].mac").signal("packetReceivedFromLower")
                  .packet("Icmpv6PacketTooBigMsg.MTU >= 1280")
                  .describe("a Packet Too Big reporting the 1280-byte next-hop MTU").within(15.0));
}

} // namespace protocoltest
} // namespace inet

%inifile: test.ini

[General]
*.tester.testName = "ipv6_icmpv6_packet_too_big_mtu"
include ../../ini/_routed.ini

**.routerB.eth[1].**.mtu = 1280B
*.host1.numApps = 1
*.host1.app[0].typename = "PingApp"
*.host1.app[0].destAddr = "host2"
*.host1.app[0].packetSize = 1400B
*.host1.app[0].startTime = 4s
*.host1.app[0].sendInterval = 1s
*.host2.numApps = 0

%expected-failure: Packet Too Big MTU field left 0 (// TODO set MTU in Ipv6.cc); PMTUD can't converge

%contains: stdout
PROTOCOLTEST ipv6_icmpv6_packet_too_big_mtu: PASS
