%description:
Mobile IPv6 route optimization. [Required -- RFC 6275 11.7.2]

Having completed return routability, the MN registers its care-of address directly with the
correspondent node so their traffic no longer detours through the Home Agent. It does this with a
Binding Update sent to the CN with the Home-Registration flag clear (a correspondent registration
rather than a home registration). Observed on the wire at the MN's wireless interface.

%file: Mipv6_RouteOptimization.cc

#include "ProtocolTest.h"

namespace inet {
namespace protocoltest {

Define_ProtocolTest(ipv6_mipv6_route_optimization)
{
    return ProtocolTest("ipv6_mipv6_route_optimization")
        .once(on("MN[0].wlan[0]").signal("packetSentToLower")
                  .packet("BindingUpdate.homeRegistrationFlag == false")
                  .describe("a correspondent-registration Binding Update (route optimization)").within(78));
}

} // namespace protocoltest
} // namespace inet

%inifile: test.ini

[General]
*.tester.testName = "ipv6_mipv6_route_optimization"
include ../../ini/_mipv6.ini

%contains: stdout
PROTOCOLTEST ipv6_mipv6_route_optimization: PASS
