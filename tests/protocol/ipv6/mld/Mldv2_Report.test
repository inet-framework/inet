%description:
MLDv2 host reports group membership with a Version 2 Report. [Required -- RFC 3810 5.2]

MLDv2 (RFC 3810) replaces MLDv1's separate Report/Done with a single Version 2 Multicast Listener
Report (type 143) carrying per-group Multicast Address Records (allowing source-specific filtering).
With MLDv2 enabled, host1 joins the source-specific group ff3e::8; observed on the wire as it
transmits a Version 2 Report.

%file: Mldv2_Report.cc

#include "ProtocolTest.h"
#include "Ipv6TestSupport.h"

namespace inet {
namespace protocoltest {

Define_ProtocolTest(ipv6_mldv2_report)
{
    return ProtocolTest("ipv6_mldv2_report")
        .once(on("host1.eth[0].mac").signal("packetSentToLower")
                  .match([](const MatchContext& c) { return chunkOfType<Mldv2Report>(c.event) != nullptr; })
                  .describe("host1's MLDv2 Multicast Listener Report").within(8.0));
}

} // namespace protocoltest
} // namespace inet

%inifile: test.ini

[General]
*.tester.testName = "ipv6_mldv2_report"
include ../../ini/_base.ini

**.ipv6.hasMld = true
**.ipv6.mld.typename = "Mldv2"
*.router.multicastForwarding = true
*.host1.numApps = 1
*.host1.app[0].typename = "UdpSink"
*.host1.app[0].localPort = 5000
*.host1.app[0].multicastGroup = "ff3e::8"

%contains: stdout
PROTOCOLTEST ipv6_mldv2_report: PASS
