%description:
A host joining a multicast group sends an MLD Multicast Listener Report. [Required -- RFC 2710 3/4]

When a host starts listening to a multicast group it announces its membership by sending a
Multicast Listener Report (type 131) for that group, so the link's querier begins forwarding
the group's traffic. host1 joins ff0e::1; observed on the wire as it transmits the Report.

%file: Mld_Report.cc

#include "ProtocolTest.h"
#include "Ipv6TestSupport.h"

namespace inet {
namespace protocoltest {

Define_ProtocolTest(ipv6_mld_report)
{
    return ProtocolTest("ipv6_mld_report")
        .once(on("host1.eth[0].mac").signal("packetSentToLower")
                  .match([](const MatchContext& c) {
                      return chunkOfType<MldReport>(c.event) != nullptr
                             && mldGroup(c.event) == Ipv6Address("ff0e::1");
                  })
                  .describe("host1's Multicast Listener Report for ff0e::1").within(8.0));
}

} // namespace protocoltest
} // namespace inet

%inifile: test.ini

[General]
*.tester.testName = "ipv6_mld_report"
include ../../ini/_base.ini

**.ipv6.hasMld = true
*.router.multicastForwarding = true
*.host1.numApps = 1
*.host1.app[0].typename = "UdpSink"
*.host1.app[0].localPort = 5000
*.host1.app[0].multicastGroup = "ff0e::1"

%contains: stdout
PROTOCOLTEST ipv6_mld_report: PASS
