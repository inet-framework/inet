%description:
MLDv2 source-specific membership (INCLUDE filter). [Required -- RFC 3810 5.2 / RFC 4604]

The point of MLDv2 over MLDv1 is source filtering: a host may subscribe to a group from specific
sources only (source-specific multicast). Such a membership is reported as a Multicast Address
Record whose source list names those sources. host1 joins ff3e::8 in INCLUDE mode for one source;
observed on the wire as it transmits a Version 2 Report carrying a source-bearing record.

%file: Mldv2_SourceInclude.cc

#include "ProtocolTest.h"
#include "Ipv6TestSupport.h"

namespace inet {
namespace protocoltest {

Define_ProtocolTest(ipv6_mldv2_source_include)
{
    return ProtocolTest("ipv6_mldv2_source_include")
        .once(on("host1.eth[0].mac").signal("packetSentToLower")
                  .match([](const MatchContext& c) { return mldv2HasSourceRecord(c.event); })
                  .describe("host1's MLDv2 Report with a source-specific (INCLUDE) record").within(8.0));
}

} // namespace protocoltest
} // namespace inet

%inifile: test.ini

[General]
*.tester.testName = "ipv6_mldv2_source_include"
include ../../ini/_base.ini

**.ipv6.hasMld = true
**.ipv6.mld.typename = "Mldv2"
*.router.multicastForwarding = true
# host1 subscribes to ff3e::8 from one source only -> MLDv2 INCLUDE membership.
*.host1.numApps = 1
*.host1.app[0].typename = "UdpSink"
*.host1.app[0].localPort = 5000
*.host1.app[0].multicastGroup = "ff3e::8"
*.host1.app[0].multicastSources = "2001:db8:1:1:8aa:ff:fe00:6"

%contains: stdout
PROTOCOLTEST ipv6_mldv2_source_include: PASS
