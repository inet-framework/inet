%description:
Address resolution: Neighbour Solicitation answered by a Neighbour Advertisement.
[Required -- RFC 4861 7.2]

To send to an on-link neighbour whose link-layer address is unknown, a node multicasts a
Neighbour Solicitation for the target and the target replies with a unicast, solicited
Neighbour Advertisement. A host1 -> host2 UDP flow (started after autoconfiguration settles)
triggers the exchange; observed on the wire at host1's interface as it transmits the NS and
then receives the solicited NA.

%file: Nd_AddressResolution.cc

#include "ProtocolTest.h"

namespace inet {
namespace protocoltest {

Define_ProtocolTest(ipv6_nd_address_resolution)
{
    return ProtocolTest("ipv6_nd_address_resolution")
        .once(on("host1.eth[0].mac").signal("packetSentToLower")
                  .packet("Ipv6NeighbourSolicitation.code == 0")
                  .describe("host1's Neighbour Solicitation to resolve host2").notBefore(3.9).within(6.0))
        .once(on("host1.eth[0].mac").signal("packetReceivedFromLower")
                  .packet("Ipv6NeighbourAdvertisement.solicitedFlag == true")
                  .describe("host2's solicited Neighbour Advertisement").within(1.0));
}

} // namespace protocoltest
} // namespace inet

%inifile: test.ini

[General]
*.tester.testName = "ipv6_nd_address_resolution"
include ../../ini/_base.ini

# A host1 -> host2 flow (after SLAAC settles) that requires resolving host2's address.
*.host1.numApps = 1
*.host1.app[0].typename = "UdpBasicApp"
*.host1.app[0].destAddresses = "host2"
*.host1.app[0].destPort = 5000
*.host1.app[0].messageLength = 100B
*.host1.app[0].sendInterval = 1s
*.host1.app[0].startTime = 4s
*.host2.numApps = 1
*.host2.app[0].typename = "UdpSink"
*.host2.app[0].localPort = 5000

%contains: stdout
PROTOCOLTEST ipv6_nd_address_resolution: PASS
