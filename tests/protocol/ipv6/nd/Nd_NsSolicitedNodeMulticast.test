%description:
Address-resolution NS is sent to the target's solicited-node multicast. [Required -- RFC 4861 7.2.2]

A Neighbour Solicitation for address resolution is destined to the solicited-node multicast
address of the target (ff02::1:ffXX:XXXX), not to the target's unicast address, so it reaches
the target while sparing unrelated nodes. Observed on the wire as host1 transmits its
resolution NS: the IPv6 source is a real (non-unspecified) address -- distinguishing it from a
DAD probe -- and the destination is a solicited-node multicast.

%file: Nd_NsSolicitedNodeMulticast.cc

#include "ProtocolTest.h"
#include "Ipv6TestSupport.h"

namespace inet {
namespace protocoltest {

Define_ProtocolTest(ipv6_nd_ns_solicited_node_multicast)
{
    return ProtocolTest("ipv6_nd_ns_solicited_node_multicast")
        .once(on("host1.eth[0].mac").signal("packetSentToLower")
                  .match([](const MatchContext& c) {
                      return chunkOfType<Ipv6NeighbourSolicitation>(c.event) != nullptr
                             && !ipv6Src(c.event).isUnspecified()
                             && isSolicitedNodeMulticast(ipv6Dst(c.event));
                  })
                  .describe("an address-resolution NS to the solicited-node multicast")
                  .notBefore(3.9).within(6.0));
}

} // namespace protocoltest
} // namespace inet

%inifile: test.ini

[General]
*.tester.testName = "ipv6_nd_ns_solicited_node_multicast"
include ../../ini/_base.ini

*.host1.numApps = 1
*.host1.app[0].typename = "UdpBasicApp"
*.host1.app[0].destAddresses = "host2"
*.host1.app[0].destPort = 5000
*.host1.app[0].messageLength = 100B
*.host1.app[0].sendInterval = 1s
*.host1.app[0].startTime = 4s
*.host2.numApps = 1
*.host2.app[0].typename = "UdpSink"
*.host2.app[0].localPort = 5000

%contains: stdout
PROTOCOLTEST ipv6_nd_ns_solicited_node_multicast: PASS
