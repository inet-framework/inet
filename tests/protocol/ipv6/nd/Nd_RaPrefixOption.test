%description:
Router Advertisement carries a Prefix Information option for SLAAC. [Required -- RFC 4861 4.6.2]

For hosts to autoconfigure, the RA must include a Prefix Information option with the
autonomous (A) flag set. The option is a TLV nested inside the RA message (not a first-class
chunk), so it is inspected in C++ via the Ipv6TestSupport helper. Observed on the wire as the
router transmits the RA.

%file: Nd_RaPrefixOption.cc

#include "ProtocolTest.h"
#include "Ipv6TestSupport.h"

namespace inet {
namespace protocoltest {

Define_ProtocolTest(ipv6_nd_ra_prefix_option)
{
    return ProtocolTest("ipv6_nd_ra_prefix_option")
        .once(on("router.eth[0].mac").signal("packetSentToLower")
                  .match([](const MatchContext& c) { return raHasAutonomousPrefix(c.event); })
                  .describe("an RA carrying an autonomous Prefix Information option")
                  .within(3.0));
}

} // namespace protocoltest
} // namespace inet

%inifile: test.ini

[General]
*.tester.testName = "ipv6_nd_ra_prefix_option"
include ../../ini/_base.ini

%contains: stdout
PROTOCOLTEST ipv6_nd_ra_prefix_option: PASS
