%description:
Router Advertisement carries a non-zero Router Lifetime. [Required -- RFC 4861 4.2]

A router willing to be a default router advertises a non-zero Router Lifetime; hosts that
receive it install it as a default router and stop soliciting. Observed on the wire as the
router transmits the RA.

%file: Nd_RaRouterLifetime.cc

#include "ProtocolTest.h"

namespace inet {
namespace protocoltest {

Define_ProtocolTest(ipv6_nd_ra_router_lifetime)
{
    return ProtocolTest("ipv6_nd_ra_router_lifetime")
        .once(on("router.eth[0].mac").signal("packetSentToLower")
                  .packet("Ipv6RouterAdvertisement.routerLifetime > 0")
                  .describe("an RA with a non-zero Router Lifetime (a default router)")
                  .within(3.0));
}

} // namespace protocoltest
} // namespace inet

%inifile: test.ini

[General]
*.tester.testName = "ipv6_nd_ra_router_lifetime"
include ../../ini/_base.ini

%contains: stdout
PROTOCOLTEST ipv6_nd_ra_router_lifetime: PASS
