%description:
Router Advertisement carries an MTU option. [Optional -- RFC 4861 4.6.4]

To keep every node on a link using the same MTU, a router may include an MTU option in its Router
Advertisements. INET always includes one. The option is a TLV nested inside the RA message, so it
is inspected in C++ via the Ipv6TestSupport helper. Observed on the wire as the router transmits
the RA.

%file: Nd_RaMtuOption.cc

#include "ProtocolTest.h"
#include "Ipv6TestSupport.h"

namespace inet {
namespace protocoltest {

Define_ProtocolTest(ipv6_nd_ra_mtu_option)
{
    return ProtocolTest("ipv6_nd_ra_mtu_option")
        .once(on("router.eth[0].mac").signal("packetSentToLower")
                  .match([](const MatchContext& c) { return raHasMtuOption(c.event); })
                  .describe("an RA carrying an MTU option").within(3.0));
}

} // namespace protocoltest
} // namespace inet

%inifile: test.ini

[General]
*.tester.testName = "ipv6_nd_ra_mtu_option"
include ../../ini/_base.ini

%contains: stdout
PROTOCOLTEST ipv6_nd_ra_mtu_option: PASS
