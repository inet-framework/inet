%description:
Byte-exact round-trip serialization of LDP packets (RFC 5036): the PDU/message header
(Section 3.5.3, 3.6), Hello, Label Request, Label Mapping (also used for Label
Withdraw/Release), Notification (with its FEC TLV), Initialization, KeepAlive, and
Address (also used for Address Withdraw). Verifies serialize->bytes->deserialize
reproduces the fields and the expected on-wire lengths (matching the B(...)/
ldpAddressMessageBytes(...) constants in Ldp.h).

Also covers the optional RFC 5036 Section 2.8 loop-detection TLVs (Hop Count/Path
Vector) that Label Request and Label Mapping messages may carry when Ldp.loopDetection
is enabled: a Label Request and a Label Mapping WITH the TLVs populated (multi-entry
path vector included, to cover the variable-length case), plus confirming that a
Label Request/Mapping WITHOUT them (hasLoopDetection left at its default false)
serializes at exactly the pre-existing base length -- the neutrality guarantee for
loopDetection=false (the model's default).

%includes:
#include "inet/common/packet/Packet.h"
#include "inet/common/packet/chunk/BytesChunk.h"
#include "inet/networklayer/ldp/LdpPacket_m.h"

using namespace inet;

%global:

template<typename T>
Ptr<const T> roundTrip(const Ptr<const T>& original)
{
    Packet pkt("test");
    pkt.insertAtFront(original);
    auto bytes = pkt.peekAllAsBytes();
    Packet pkt2("test2");
    pkt2.insertAtFront(bytes);
    return pkt2.popAtFront<T>(pkt2.getDataLength());
}

static void fillHeader(LdpPacket *p, int type, Ipv4Address lsrId)
{
    p->setVersion(1);
    p->setType(type);
    p->setLsrId(lsrId);
    p->setLabelSpace(0);
    p->setMessageId(0);
}

%activity:

// === 1. Hello ===
{
    EV << "=== Hello ===" << endl;
    auto hello = makeShared<LdpHello>();
    fillHeader(hello.get(), HELLO, Ipv4Address("10.0.0.1"));
    hello->setChunkLength(B(26));
    hello->setHoldTime(15);
    hello->setTbit(false);
    hello->setRbit(true);

    Packet pkt("sz"); pkt.insertAtFront(hello);
    ASSERT(pkt.getDataLength() == B(26));
    auto h2 = dynamicPtrCast<const LdpHello>(roundTrip(staticPtrCast<const LdpPacket>(hello)));
    ASSERT(h2 != nullptr);
    ASSERT(h2->getVersion() == 1);
    ASSERT(h2->getLsrId() == Ipv4Address("10.0.0.1"));
    ASSERT(h2->getType() == HELLO);
    ASSERT(h2->getHoldTime() == 15);
    ASSERT(h2->getTbit() == false && h2->getRbit() == true);
    EV << "  PASS" << endl;
}

// === 2. Label Request ===
{
    EV << "=== LabelRequest ===" << endl;
    auto req = makeShared<LdpLabelRequest>();
    fillHeader(req.get(), LABEL_REQUEST, Ipv4Address("10.0.0.2"));
    req->setChunkLength(B(30));
    FecTlv fec;
    fec.addr = Ipv4Address("192.168.1.0");
    fec.length = 24;
    req->setFec(fec);

    Packet pkt("sz"); pkt.insertAtFront(req);
    ASSERT(pkt.getDataLength() == B(30));
    auto r2 = dynamicPtrCast<const LdpLabelRequest>(roundTrip(staticPtrCast<const LdpPacket>(req)));
    ASSERT(r2 != nullptr);
    ASSERT(r2->getLsrId() == Ipv4Address("10.0.0.2"));
    ASSERT(r2->getFec().addr == Ipv4Address("192.168.1.0") && r2->getFec().length == 24);
    // loopDetection=false neutrality: no loop-detection TLVs written/read
    ASSERT(r2->getHasLoopDetection() == false);
    EV << "  PASS" << endl;
}

// === 3. Label Mapping ===
{
    EV << "=== LabelMapping ===" << endl;
    auto map = makeShared<LdpLabelMapping>();
    fillHeader(map.get(), LABEL_MAPPING, Ipv4Address("10.0.0.3"));
    map->setChunkLength(B(38));
    FecTlv fec;
    fec.addr = Ipv4Address("172.16.0.0");
    fec.length = 16;
    map->setFec(fec);
    map->setLabel(1234);

    Packet pkt("sz"); pkt.insertAtFront(map);
    ASSERT(pkt.getDataLength() == B(38));
    auto m2 = dynamicPtrCast<const LdpLabelMapping>(roundTrip(staticPtrCast<const LdpPacket>(map)));
    ASSERT(m2 != nullptr);
    ASSERT(m2->getFec().addr == Ipv4Address("172.16.0.0") && m2->getFec().length == 16);
    ASSERT(m2->getLabel() == 1234);
    // loopDetection=false neutrality: no loop-detection TLVs written/read
    ASSERT(m2->getHasLoopDetection() == false);
    EV << "  PASS" << endl;
}

// === 4. Label Withdraw / Label Release (same class, different type) ===
{
    EV << "=== LabelWithdraw/Release ===" << endl;
    for (int msgType : { LABEL_WITHDRAW, LABEL_RELEASE }) {
        auto map = makeShared<LdpLabelMapping>();
        fillHeader(map.get(), msgType, Ipv4Address("10.0.0.4"));
        map->setChunkLength(B(38));
        FecTlv fec;
        fec.addr = Ipv4Address("10.10.0.0");
        fec.length = 16;
        map->setFec(fec);
        map->setLabel(17);

        Packet pkt("sz"); pkt.insertAtFront(map);
        ASSERT(pkt.getDataLength() == B(38));
        auto m2 = dynamicPtrCast<const LdpLabelMapping>(roundTrip(staticPtrCast<const LdpPacket>(map)));
        ASSERT(m2 != nullptr);
        ASSERT(m2->getType() == msgType);
        ASSERT(m2->getLabel() == 17);
    }
    EV << "  PASS" << endl;
}

// === 5. Notification (with its always-present FEC TLV) ===
{
    EV << "=== Notification ===" << endl;
    auto notify = makeShared<LdpNotify>();
    fillHeader(notify.get(), NOTIFICATION, Ipv4Address("10.0.0.5"));
    notify->setChunkLength(B(44));
    notify->setStatus(NO_ROUTE);
    FecTlv fec;
    fec.addr = Ipv4Address("203.0.113.0");
    fec.length = 24;
    notify->setFec(fec);

    Packet pkt("sz"); pkt.insertAtFront(notify);
    ASSERT(pkt.getDataLength() == B(44));
    auto n2 = dynamicPtrCast<const LdpNotify>(roundTrip(staticPtrCast<const LdpPacket>(notify)));
    ASSERT(n2 != nullptr);
    ASSERT(n2->getStatus() == NO_ROUTE);
    ASSERT(n2->getFec().addr == Ipv4Address("203.0.113.0") && n2->getFec().length == 24);
    EV << "  PASS" << endl;
}

// === 6. Initialization (unwired, but must still be serializable) ===
{
    EV << "=== Initialization ===" << endl;
    auto ini = makeShared<LdpIni>();
    fillHeader(ini.get(), INITIALIZATION, Ipv4Address("10.0.0.6"));
    ini->setChunkLength(B(38)); // PDU header(10) + message header(8) + Common Session Parameters TLV(20)
    ini->setKeepAliveTime(180);
    ini->setAbit(true);
    ini->setDbit(false);
    ini->setPvLim(0);
    ini->setMaxPduLength(4096);
    ini->setReceiverLsrId(Ipv4Address("10.0.0.7"));
    ini->setReceiverLabelSpace(0);

    Packet pkt("sz"); pkt.insertAtFront(ini);
    ASSERT(pkt.getDataLength() == B(38));
    auto i2 = dynamicPtrCast<const LdpIni>(roundTrip(staticPtrCast<const LdpPacket>(ini)));
    ASSERT(i2 != nullptr);
    ASSERT(i2->getKeepAliveTime() == 180);
    ASSERT(i2->getAbit() == true && i2->getDbit() == false);
    ASSERT(i2->getMaxPduLength() == 4096);
    ASSERT(i2->getReceiverLsrId() == Ipv4Address("10.0.0.7"));
    EV << "  PASS" << endl;
}

// === 7. KeepAlive (no message parameters) ===
{
    EV << "=== KeepAlive ===" << endl;
    auto ka = makeShared<LdpKeepAlive>();
    fillHeader(ka.get(), KEEP_ALIVE, Ipv4Address("10.0.0.11"));
    ka->setChunkLength(B(18)); // PDU header(10) + message header(8), no message parameters

    Packet pkt("sz"); pkt.insertAtFront(ka);
    ASSERT(pkt.getDataLength() == B(18));
    auto k2 = dynamicPtrCast<const LdpKeepAlive>(roundTrip(staticPtrCast<const LdpPacket>(ka)));
    ASSERT(k2 != nullptr);
    ASSERT(k2->getVersion() == 1);
    ASSERT(k2->getLsrId() == Ipv4Address("10.0.0.11"));
    ASSERT(k2->getType() == KEEP_ALIVE);
    EV << "  PASS" << endl;
}

// === 8. Address / Address Withdraw (same class, different type) ===
{
    EV << "=== Address/AddressWithdraw ===" << endl;
    for (int msgType : { ADDRESS, ADDRESS_WITHDRAW }) {
        auto addr = makeShared<LdpAddress>();
        fillHeader(addr.get(), msgType, Ipv4Address("10.0.0.8"));
        addr->setChunkLength(B(10 + 8 + 4 + 2 + 4 * 2)); // PDU hdr + msg hdr + TLV hdr + addr family + 2 addresses
        addr->setIsWithdraw(msgType == ADDRESS_WITHDRAW);
        addr->setAddressFamily(1);
        addr->setAddressesArraySize(2);
        addr->setAddresses(0, Ipv4Address("10.0.0.9"));
        addr->setAddresses(1, Ipv4Address("10.0.0.10"));

        Packet pkt("sz"); pkt.insertAtFront(addr);
        ASSERT(pkt.getDataLength() == B(32));
        auto a2 = dynamicPtrCast<const LdpAddress>(roundTrip(staticPtrCast<const LdpPacket>(addr)));
        ASSERT(a2 != nullptr);
        ASSERT(a2->getType() == msgType);
        ASSERT(a2->isWithdraw() == (msgType == ADDRESS_WITHDRAW));
        ASSERT(a2->getAddressFamily() == 1);
        ASSERT(a2->getAddressesArraySize() == 2);
        ASSERT(a2->getAddresses(0) == Ipv4Address("10.0.0.9"));
        ASSERT(a2->getAddresses(1) == Ipv4Address("10.0.0.10"));
    }
    EV << "  PASS" << endl;
}

// === 9. Label Request with loop detection (RFC 5036 Section 2.8: Hop Count + Path Vector TLVs) ===
{
    EV << "=== LabelRequest with loop detection ===" << endl;
    auto req = makeShared<LdpLabelRequest>();
    fillHeader(req.get(), LABEL_REQUEST, Ipv4Address("10.0.0.12"));
    FecTlv fec;
    fec.addr = Ipv4Address("192.168.2.0");
    fec.length = 24;
    req->setFec(fec);
    req->setHasLoopDetection(true);
    req->setHopCount(3);
    req->setPathVectorArraySize(2); // multi-entry, to cover the variable-length TLV case
    req->setPathVector(0, Ipv4Address("10.0.0.1"));
    req->setPathVector(1, Ipv4Address("10.0.0.2"));
    // base Label Request (30) + Hop Count TLV (4 hdr + 1 value = 5) + Path Vector TLV (4 hdr + 2 * 4 bytes = 12)
    req->setChunkLength(B(30 + 5 + 12));

    Packet pkt("sz"); pkt.insertAtFront(req);
    ASSERT(pkt.getDataLength() == B(47));
    auto r2 = dynamicPtrCast<const LdpLabelRequest>(roundTrip(staticPtrCast<const LdpPacket>(req)));
    ASSERT(r2 != nullptr);
    ASSERT(r2->getFec().addr == Ipv4Address("192.168.2.0") && r2->getFec().length == 24);
    ASSERT(r2->getHasLoopDetection() == true);
    ASSERT(r2->getHopCount() == 3);
    ASSERT(r2->getPathVectorArraySize() == 2);
    ASSERT(r2->getPathVector(0) == Ipv4Address("10.0.0.1"));
    ASSERT(r2->getPathVector(1) == Ipv4Address("10.0.0.2"));
    EV << "  PASS" << endl;
}

// === 10. Label Mapping with loop detection ===
{
    EV << "=== LabelMapping with loop detection ===" << endl;
    auto map = makeShared<LdpLabelMapping>();
    fillHeader(map.get(), LABEL_MAPPING, Ipv4Address("10.0.0.13"));
    FecTlv fec;
    fec.addr = Ipv4Address("172.16.1.0");
    fec.length = 24;
    map->setFec(fec);
    map->setLabel(555);
    map->setHasLoopDetection(true);
    map->setHopCount(2);
    map->setPathVectorArraySize(1);
    map->setPathVector(0, Ipv4Address("10.0.0.3"));
    // base Label Mapping (38) + Hop Count TLV (5) + Path Vector TLV (4 hdr + 1 * 4 bytes = 8)
    map->setChunkLength(B(38 + 5 + 8));

    Packet pkt("sz"); pkt.insertAtFront(map);
    ASSERT(pkt.getDataLength() == B(51));
    auto m2 = dynamicPtrCast<const LdpLabelMapping>(roundTrip(staticPtrCast<const LdpPacket>(map)));
    ASSERT(m2 != nullptr);
    ASSERT(m2->getLabel() == 555);
    ASSERT(m2->getHasLoopDetection() == true);
    ASSERT(m2->getHopCount() == 2);
    ASSERT(m2->getPathVectorArraySize() == 1);
    ASSERT(m2->getPathVector(0) == Ipv4Address("10.0.0.3"));
    EV << "  PASS" << endl;
}

EV << "All LDP serializer round-trips passed." << endl;

%contains: stdout
All LDP serializer round-trips passed.
