%description:
Sanity-checks Tcp::generateFastOpenCookie(): deterministic for a fixed
secret+address (same address twice gives the same cookie) and distinct
across addresses (falsification: checked first, so a broken constant
implementation would fail here rather than passing trivially).

%includes:
#include <iomanip>
#include <sstream>

#include "inet/transportlayer/tcp/Tcp.h"
#include "inet/networklayer/common/L3Address.h"
#include "inet/networklayer/contract/ipv4/Ipv4Address.h"

%global:

using namespace inet;
using namespace inet::tcp;

static std::string toHex(const std::vector<uint8_t>& v)
{
    std::ostringstream out;
    for (uint8_t b : v)
        out << std::hex << std::setw(2) << std::setfill('0') << (int)b;
    return out.str();
}

%activity:

Tcp tcpMain;
L3Address addr1(Ipv4Address("10.0.0.1"));
L3Address addr2(Ipv4Address("10.0.0.2"));

// Falsification first: two DIFFERENT addresses must not collide -- catches a
// broken (constant) implementation before the equality check below could pass trivially.
std::vector<uint8_t> c1 = tcpMain.generateFastOpenCookie(addr1, 8);
std::vector<uint8_t> c2 = tcpMain.generateFastOpenCookie(addr2, 8);
EV << "addr1 != addr2 cookie: " << (toHex(c1) != toHex(c2) ? "distinct" : "COLLIDED") << "\n";

// Deterministic for a fixed secret+address.
std::vector<uint8_t> c1again = tcpMain.generateFastOpenCookie(addr1, 8);
EV << "addr1 repeat cookie: " << (toHex(c1) == toHex(c1again) ? "stable" : "CHANGED") << "\n";

EV << "cookie length: " << c1.size() << "\n";

EV << ".\n";

%contains: stdout
addr1 != addr2 cookie: distinct
addr1 repeat cookie: stable
cookie length: 8
.
