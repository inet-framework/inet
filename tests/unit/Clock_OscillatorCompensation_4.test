%description:
Tests clock oscillator compensation factor with using tick events.

%includes:
#include "inet/clock/model/SettableClock.h"

using namespace omnetpp;
using namespace inet;

%file: TestNetwork.ned

import inet.clock.model.SettableClock;

network TestNetwork
{
    submodules:
        clock: SettableClock;
}

%inifile: omnetpp.ini
[General]
ned-path = .;../../../../src;../../lib
network = TestNetwork
sim-time-limit = 0.1s

*.clock.oscillatorCompensation = 100000ppm
*.clock.useFutureEventSet = false
*.clock.oscillator.nominalTickLength = 1us

%# remove formatting
%subst: /\x1B\[[0-9;]*m//

%contains: stdout
** Event #1  t=0.000001  0% completed  (0% total)   TestNetwork.clock.oscillator (ConstantDriftOscillator, id=3)
Handling tick, numTicks = 1.
Oscillator tick processed, clockTime = 0.000001.
** Event #2  t=0.000002  0% completed  (0% total)   TestNetwork.clock.oscillator (ConstantDriftOscillator, id=3)
Handling tick, numTicks = 2.
Oscillator tick processed, clockTime = 0.000002.

%contains: stdout
** Event #99999  t=0.099999  99% completed  (99% total)   TestNetwork.clock.oscillator (ConstantDriftOscillator, id=3)
Handling tick, numTicks = 99999.
Oscillator tick processed, clockTime = 0.109998.
** Event #100000  t=0.1  100% completed  (100% total)   TestNetwork.clock.oscillator (ConstantDriftOscillator, id=3)
Handling tick, numTicks = 100000.
Oscillator tick processed, clockTime = 0.11.
